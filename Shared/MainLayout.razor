@inherits LayoutComponentBase
@implements IDisposable
@inject Supabase.Client Supabase
@inject NavigationManager Nav

<div class="page">

    <!-- Top Nav Bar -->
    <div class="top-row ps-3 navbar navbar-dark bg-dark shadow-sm">
        <div class="container-fluid d-flex align-items-center justify-content-between">
            <a class="navbar-brand fw-bold" href="">🚗 <span class="brand-text">FLEET MANAGEMENT</span></a>

            <!-- Profile Button -->
            <div class="position-relative me-2">
                <button class="btn btn-outline-light btn-sm d-flex align-items-center gap-2"
                        @onclick="ToggleProfile">
                    <i class="bi bi-person-circle fs-5"></i>
                    <span class="d-none d-sm-inline">@userName</span>
                    @if (!string.IsNullOrEmpty(userRole))
                    {
                        <span class="badge @(userRole == "Admin" ? "bg-warning text-dark" : "bg-info text-dark")">
                            @userRole
                        </span>
                    }
                </button>

                <!-- Profile Dropdown -->
                @if (showProfile)
                {
                    <div class="profile-dropdown card shadow p-3">
                        <div class="text-center mb-2">
                            <i class="bi bi-person-circle display-5 text-secondary"></i>
                        </div>
                        <p class="mb-0 fw-bold text-center">@userName</p>
                        <p class="mb-1 text-center small text-muted">@userEmail</p>
                        <p class="mb-2 text-center">
                            <span class="badge @(userRole == "Admin" ? "bg-warning text-dark" : "bg-info text-dark") px-3">
                                @(userRole == "Admin" ? "Administrator" : "Driver")
                            </span>
                        </p>
                        <hr class="my-2"/>
                        <div class="d-grid gap-2">
                            <button class="btn btn-sm btn-outline-secondary" @onclick="OpenProfile">
                                <i class="bi bi-person me-1"></i> View Profile
                            </button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="Logout">
                                <i class="bi bi-box-arrow-right me-1"></i> Logout
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Desktop/Tablet: Sidebar + Content -->
    <div class="layout-body">

        <!-- Sidebar (hidden on mobile, visible md+) -->
        <div class="sidebar bg-dark text-white p-3">
            @if (userRole == "Admin")
            {
                <div class="nav-item mb-2">
                    <NavLink class="nav-link text-white rounded" href="admin" Match="NavLinkMatch.All">
                        <i class="bi bi-speedometer2 me-2"></i> Dashboard
                    </NavLink>
                </div>
                <div class="nav-item mb-2">
                    <NavLink class="nav-link text-white rounded" href="admin/settings">
                        <i class="bi bi-gear me-2"></i> Settings
                    </NavLink>
                </div>
            }
            else if (userRole == "Driver")
            {
                <div class="nav-item mb-2">
                    <NavLink class="nav-link text-white rounded" href="driver" Match="NavLinkMatch.All">
                        <i class="bi bi-truck me-2"></i> My Vehicle
                    </NavLink>
                </div>
            }
        </div>

        <!-- Main Content -->
        <main class="main-content bg-light">
            @Body
        </main>

    </div>

    <!-- Mobile Bottom Nav (visible only on small screens) -->
    <nav class="mobile-bottom-nav bg-dark d-md-none">
        @if (userRole == "Admin")
        {
            <NavLink class="mobile-nav-item text-white" href="admin" Match="NavLinkMatch.All">
                <i class="bi bi-speedometer2"></i>
                <span>Dashboard</span>
            </NavLink>
            <NavLink class="mobile-nav-item text-white" href="admin/settings">
                <i class="bi bi-gear"></i>
                <span>Settings</span>
            </NavLink>
        }
        else if (userRole == "Driver")
        {
            <NavLink class="mobile-nav-item text-white" href="driver" Match="NavLinkMatch.All">
                <i class="bi bi-truck"></i>
                <span>My Vehicle</span>
            </NavLink>
        }
        <button class="mobile-nav-item text-white border-0 bg-transparent" @onclick="OpenProfile">
            <i class="bi bi-person-circle"></i>
            <span>Profile</span>
        </button>
    </nav>

</div>

<!-- Click outside to close profile dropdown -->
@if (showProfile)
{
    <div class="position-fixed top-0 start-0 w-100 h-100"
         style="z-index: 999;"
         @onclick="ToggleProfile">
    </div>
}

<!-- View Profile Modal -->
@if (showProfileModal)
{
    <div class="modal fade show d-block" tabindex="-1"
         style="background-color: rgba(0,0,0,0.5); z-index: 1055;">
        <div class="modal-dialog modal-dialog-centered modal-fullscreen-sm-down">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-person-circle me-2"></i> My Profile
                    </h5>
                    <button type="button" class="btn-close"
                            @onclick="() => showProfileModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="text-center mb-4">
                        <i class="bi bi-person-circle display-3 text-secondary"></i>
                        <h5 class="mt-2 mb-0">@userName</h5>
                        <span class="badge @(userRole == "Admin" ? "bg-warning text-dark" : "bg-info text-dark") px-3 mt-1">
                            @(userRole == "Admin" ? "Administrator" : "Driver")
                        </span>
                    </div>
                    <div class="list-group list-group-flush">
                        <div class="list-group-item d-flex justify-content-between flex-wrap gap-1">
                            <span class="text-muted"><i class="bi bi-person me-2"></i>Name</span>
                            <span class="fw-semibold">@userName</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between flex-wrap gap-1">
                            <span class="text-muted"><i class="bi bi-envelope me-2"></i>Email</span>
                            <span class="fw-semibold text-break">@userEmail</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between flex-wrap gap-1">
                            <span class="text-muted"><i class="bi bi-phone me-2"></i>Phone</span>
                            <span class="fw-semibold">@(string.IsNullOrEmpty(userPhone) ? "Not set" : userPhone)</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between flex-wrap gap-1">
                            <span class="text-muted"><i class="bi bi-shield me-2"></i>Role</span>
                            <span class="fw-semibold">@userRole</span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer flex-column gap-2">
                    <button class="btn btn-danger w-100" @onclick="Logout">
                        <i class="bi bi-box-arrow-right me-1"></i> Logout
                    </button>
                    <button class="btn btn-secondary w-100"
                            @onclick="() => showProfileModal = false">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    :root { --app-primary: #0d6efd; }

    .btn-primary {
        background-color: var(--app-primary) !important;
        border-color: var(--app-primary) !important;
    }

    .top-row {
        height: 56px;
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .layout-body {
        display: flex;
        min-height: calc(100vh - 56px);
    }

    .sidebar {
        width: 220px;
        min-width: 220px;
        flex-shrink: 0;
    }

    .sidebar .nav-link:hover { background-color: rgba(255,255,255,0.1); }
    .sidebar .nav-link.active {
        background-color: rgba(255,255,255,0.2);
        font-weight: bold;
    }

    .main-content {
        flex: 1;
        padding: 1rem;
        min-width: 0;
    }

    .profile-dropdown {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        width: 240px;
        border-radius: 12px;
        z-index: 1000;
        background: white;
    }

    .mobile-bottom-nav {
        display: none;
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        height: 64px;
        z-index: 200;
        flex-direction: row;
        align-items: center;
        justify-content: space-around;
        border-top: 1px solid rgba(255,255,255,0.1);
        padding-bottom: env(safe-area-inset-bottom, 0px);
    }

    .mobile-nav-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2px;
        padding: 6px 16px;
        font-size: 0.7rem;
        text-decoration: none;
        opacity: 0.7;
        transition: opacity 0.15s;
        cursor: pointer;
    }

    .mobile-nav-item i { font-size: 1.3rem; }

    .mobile-nav-item.active,
    .mobile-nav-item:hover { opacity: 1; }

    @@media (min-width: 768px) and (max-width: 991px) {
        .sidebar {
            width: 64px;
            min-width: 64px;
            padding: 0.75rem 0.5rem !important;
        }
        .sidebar .nav-link {
            display: flex;
            justify-content: center;
            padding: 0.6rem;
        }
        .sidebar .nav-link i { margin: 0 !important; font-size: 1.3rem; }
        .sidebar .nav-link span { display: none; }
        .brand-text { display: none; }
    }

    @@media (max-width: 767.98px) {
        .sidebar { display: none !important; }
        .mobile-bottom-nav { display: flex !important; }
        .main-content {
            padding: 0.75rem;
            padding-bottom: calc(64px + env(safe-area-inset-bottom, 0px) + 0.75rem);
        }
        .brand-text { display: none; }
        .profile-dropdown {
            position: fixed;
            top: 60px;
            right: 8px;
            left: 8px;
            width: auto;
        }
    }

    @@media (max-width: 399px) {
        .main-content { padding: 0.5rem; }
    }
</style>

@code {
    private bool showProfile = false;
    private bool showProfileModal = false;
    private string userEmail = "";
    private string userName = "";
    private string userRole = "";
    private string userPhone = "";

    protected override void OnInitialized()
    {
        Supabase.Auth.AddStateChangedListener(async (sender, state) =>
        {
            await OnAuthStateChanged(state.ToString());
        });

        var email = Supabase.Auth.CurrentSession?.User?.Email;
        if (!string.IsNullOrEmpty(email))
        {
            _ = LoadUserAsync(email);
        }
    }

    private async Task OnAuthStateChanged(string state)
    {
        if (state == "SignedIn")
        {
            var email = Supabase.Auth.CurrentSession?.User?.Email;
            if (!string.IsNullOrEmpty(email))
            {
                await LoadUserAsync(email);
                await InvokeAsync(StateHasChanged);
            }
        }
        else if (state == "SignedOut")
        {
            userEmail = "";
            userName = "";
            userRole = "";
            userPhone = "";
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadUserAsync(string email)
    {
        userEmail = email;
        try
        {
            var result = await Supabase
                .From<FleetManagement.Models.Driver>()
                .Filter("email", Postgrest.Constants.Operator.Equals, email)
                .Single();

            if (result != null)
            {
                userName = result.Name;
                userRole = result.Role;
                userPhone = result.Phone ?? "";
            }
            else
            {
                userName = email;
            }
        }
        catch
        {
            userName = email;
            userRole = "";
        }
    }

    public void Dispose() { }

    private void ToggleProfile() => showProfile = !showProfile;

    private void OpenProfile()
    {
        showProfile = false;
        showProfileModal = true;
    }

    private async Task Logout()
    {
        await Supabase.Auth.SignOut();
        showProfile = false;
        showProfileModal = false;
        Nav.NavigateTo("/", forceLoad: true);
    }
}