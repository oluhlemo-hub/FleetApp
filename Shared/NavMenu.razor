<div class="top-row ps-3 navbar navbar-dark bg-dark shadow-sm">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="">FLEET MANAGEMENT</a>
    </div>
</div>

<div class="flex-column p-3">
    @if (IsAdmin)
    {
        <div class="nav-item px-3 mb-2">
            <NavLink class="nav-link rounded" href="admin" Match="NavLinkMatch.All">
                <i class="bi bi-speedometer2 me-2"></i> Admin Dashboard
            </NavLink>
        </div>
        <div class="nav-item px-3 mb-2">
            <NavLink class="nav-link rounded" href="admin/settings">
                <i class="bi bi-gear me-2"></i> Settings
            </NavLink>
        </div>
    }
    else
    {
        <div class="nav-item px-3">
            <NavLink class="nav-link rounded" href="driver" Match="NavLinkMatch.All">
                <i class="bi bi-truck me-2"></i> My Vehicle
            </NavLink>
        </div>
    }
</div>

@code {
    [Parameter] public bool IsAdmin { get; set; } = true;
}
