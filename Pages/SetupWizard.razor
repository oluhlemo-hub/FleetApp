@page "/setup"
@layout FleetManagement.Shared.EmptyLayout
@inject Supabase.Client Supabase
@inject NavigationManager Nav
@inject FleetManagement.Services.ThemeService ThemeService

<div class="setup-page @ThemeService.ThemeClass">

    <div class="setup-progress">
        @for (int i = 1; i <= totalSteps; i++)
        {
            var stepNum = i;
            <div class="setup-progress-step @(stepNum < currentStep ? "done" : stepNum == currentStep ? "active" : "")">
                @if (stepNum < currentStep) { <i class="bi bi-check-lg"></i> } else { @stepNum }
            </div>
            @if (stepNum < totalSteps)
            {
                <div class="setup-progress-line @(stepNum < currentStep ? "done" : "")"></div>
            }
        }
    </div>

    <div class="setup-card">

        @if (currentStep == 1)
        {
            <div class="setup-step text-center">
                <div class="setup-welcome-icon"><i class="bi bi-truck fs-1 text-primary"></i></div>
                <h2 class="setup-heading mt-3">Welcome, @driverName! 👋</h2>
                <p class="setup-subtext">You've been added to <strong>@companyName</strong>.<br/>Let's take a moment to set up your profile.</p>
                <div class="setup-info-row">
                    <span class="setup-info-item"><i class="bi bi-camera me-2"></i>Profile picture</span>
                    <span class="setup-info-item"><i class="bi bi-palette me-2"></i>App theme</span>
                    <span class="setup-info-item"><i class="bi bi-lock me-2"></i>Set password</span>
                </div>
            </div>
        }

        @if (currentStep == 2)
        {
            <div class="setup-step text-center">
                <h2 class="setup-heading">Add a profile picture</h2>
                <p class="setup-subtext">This will appear on your profile and in the driver list.</p>
                <label for="avatarInput" class="setup-avatar-upload">
                    @if (!string.IsNullOrEmpty(previewUrl))
                    {
                        <img src="@previewUrl" class="setup-avatar-img" alt="Preview" />
                    }
                    else
                    {
                        <div class="setup-avatar-placeholder">
                            <i class="bi bi-person-circle"></i>
                            <span>Tap to upload</span>
                        </div>
                    }
                    <div class="setup-avatar-overlay"><i class="bi bi-camera-fill"></i></div>
                </label>
                <InputFile id="avatarInput" OnChange="OnFileSelected" accept="image/*" style="display:none;" />
                @if (!string.IsNullOrEmpty(uploadError))
                {
                    <div class="alert alert-danger mt-3 py-2 small">@uploadError</div>
                }
                @if (isUploading)
                {
                    <div class="mt-3 text-muted small"><span class="spinner-border spinner-border-sm me-2"></span>Uploading...</div>
                }
            </div>
        }

        @if (currentStep == 3)
        {
            <div class="setup-step">
                <h2 class="setup-heading text-center">Choose your theme</h2>
                <p class="setup-subtext text-center">You can change this anytime in Settings.</p>
                <div class="setup-theme-grid">
                    @foreach (var t in new[] { ("Light","bi-sun","Clean white interface"), ("Dark","bi-moon-stars","Easy on the eyes"), ("System","bi-circle-half","Follows your device") })
                    {
                        var theme = t;
                        <button class="setup-theme-card @(selectedTheme == theme.Item1 ? "selected" : "")" @onclick="() => SelectTheme(theme.Item1)">
                            <i class="bi @theme.Item2 setup-theme-icon"></i>
                            <div>
                                <div class="setup-theme-name">@theme.Item1</div>
                                <div class="setup-theme-desc">@theme.Item3</div>
                            </div>
                            @if (selectedTheme == theme.Item1) { <i class="bi bi-check-circle-fill ms-auto text-primary"></i> }
                        </button>
                    }
                </div>
            </div>
        }

        @if (currentStep == 4)
        {
            <div class="setup-step">
                <h2 class="setup-heading text-center">Set your password</h2>
                <p class="setup-subtext text-center">Choose a secure password for your account.</p>
                <div class="mt-3">
                    <label class="setup-label">New Password</label>
                    <div class="setup-input-wrap mb-3">
                        <input type="@(showPassword ? "text" : "password")" class="setup-input" @bind="newPassword" placeholder="At least 8 characters" />
                        <button type="button" class="setup-input-toggle" @onclick="() => showPassword = !showPassword">
                            <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                        </button>
                    </div>
                    <label class="setup-label">Confirm Password</label>
                    <div class="setup-input-wrap">
                        <input type="@(showPassword ? "text" : "password")" class="setup-input" @bind="confirmPassword" placeholder="Repeat your password" />
                    </div>
                    @if (!string.IsNullOrEmpty(passwordError))
                    {
                        <div class="alert alert-danger mt-3 py-2 small">@passwordError</div>
                    }
                </div>
            </div>
        }

        @if (currentStep == 5)
        {
            <div class="setup-step text-center">
                <div class="mt-2 mb-3">
                    @if (!string.IsNullOrEmpty(finalAvatarUrl))
                    {
                        <img src="@finalAvatarUrl" class="setup-done-avatar" alt="@driverName" />
                    }
                    else
                    {
                        <div class="setup-done-initials">@(driverName.Length > 0 ? driverName[0].ToString().ToUpper() : "?")</div>
                    }
                </div>
                <h2 class="setup-heading">You're all set, @driverName! 🎉</h2>
                <p class="setup-subtext">Your profile is ready. Would you like a quick tour of the app?</p>
                <div class="d-flex flex-column gap-2 mt-3">
                    <button class="btn btn-primary setup-btn" @onclick="FinishWithTour"><i class="bi bi-map me-2"></i>Show me around</button>
                    <button class="setup-btn-outline" @onclick="FinishWithoutTour">Skip tour, take me in</button>
                </div>
            </div>
        }

        @if (currentStep < 5)
        {
            <div class="setup-nav">
                @if (currentStep > 1)
                {
                    <button class="setup-back-btn" @onclick="PrevStep" disabled="@(isUploading || isSaving)"><i class="bi bi-arrow-left me-1"></i> Back</button>
                }
                else { <div></div> }

                @if (currentStep == 4)
                {
                    <button class="setup-next-btn" @onclick="SavePasswordAndFinish" disabled="@isSaving">
                        @if (isSaving) { <span class="spinner-border spinner-border-sm me-2"></span> }
                        Finish <i class="bi bi-check-lg ms-1"></i>
                    </button>
                }
                else
                {
                    <button class="setup-next-btn" @onclick="NextStep" disabled="@isUploading">
                        @(currentStep == 2 && string.IsNullOrEmpty(previewUrl) ? "Skip for now" : "Next") <i class="bi bi-arrow-right ms-1"></i>
                    </button>
                }
            </div>
            <div class="text-center mt-3">
                <button class="setup-skip-link" @onclick="SkipSetup">Skip setup for now</button>
            </div>
        }

    </div>
</div>

<style>
    .setup-page { min-height:100vh;background:var(--page-bg,#f8fafc);display:flex;flex-direction:column;align-items:center;justify-content:flex-start;padding:2rem 1rem 4rem;color:var(--text-main,#111); }
    .setup-progress { display:flex;align-items:center;margin-bottom:2rem; }
    .setup-progress-step { width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:600;background:#fff;border:2px solid #cbd5e1;color:#94a3b8;transition:all 0.25s;flex-shrink:0; }
    .setup-progress-step.active { background:#185FA5;border-color:#185FA5;color:#fff; }
    .setup-progress-step.done { background:#22c55e;border-color:#22c55e;color:#fff; }
    .setup-progress-line { width:40px;height:2px;background:#cbd5e1;transition:background 0.25s; }
    .setup-progress-line.done { background:#22c55e; }
    .setup-card { width:100%;max-width:480px;background:var(--card-bg,#fff);border-radius:16px;padding:2rem;border:1px solid var(--border-color,#e2e8f0);box-shadow:0 4px 24px rgba(4,44,83,0.10); }
    .setup-step { min-height:260px;display:flex;flex-direction:column;justify-content:center; }
    .setup-heading { font-size:1.4rem;font-weight:700;margin-bottom:0.5rem; }
    .setup-subtext { color:var(--text-muted,#64748b);font-size:0.925rem;line-height:1.5; }
    .setup-welcome-icon { width:72px;height:72px;background:var(--navy-50,#E6F1FB);border-radius:18px;display:flex;align-items:center;justify-content:center;margin:0 auto; }
    .setup-info-row { display:flex;flex-wrap:wrap;gap:0.75rem;justify-content:center;margin-top:1.5rem; }
    .setup-info-item { background:var(--surface-raised,#f1f5f9);border:1px solid var(--border-color,#e2e8f0);border-radius:20px;padding:6px 14px;font-size:0.8rem;color:var(--text-muted,#64748b); }
    .setup-avatar-upload { position:relative;width:120px;height:120px;border-radius:50%;margin:1.5rem auto;cursor:pointer;overflow:hidden;border:3px dashed #cbd5e1;display:block;transition:border-color 0.2s; }
    .setup-avatar-upload:hover { border-color:#378ADD; }
    .setup-avatar-img { width:100%;height:100%;object-fit:cover;border-radius:50%; }
    .setup-avatar-placeholder { width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;color:#94a3b8;font-size:0.75rem;gap:4px; }
    .setup-avatar-placeholder i { font-size:2.5rem; }
    .setup-avatar-overlay { position:absolute;bottom:0;left:0;right:0;background:rgba(4,44,83,0.6);display:flex;align-items:center;justify-content:center;height:36px;color:#fff;font-size:1rem;opacity:0;transition:opacity 0.2s; }
    .setup-avatar-upload:hover .setup-avatar-overlay { opacity:1; }
    .setup-theme-grid { display:flex;flex-direction:column;gap:0.75rem;margin-top:1rem; }
    .setup-theme-card { display:flex;align-items:center;gap:1rem;padding:1rem 1.25rem;border-radius:12px;border:2px solid var(--border-color,#e2e8f0);background:var(--surface-raised,#f8fafc);cursor:pointer;transition:border-color 0.2s; }
    .setup-theme-card.selected { border-color:#185FA5;background:#EFF6FF; }
    .setup-theme-icon { font-size:1.5rem;color:#378ADD;flex-shrink:0; }
    .setup-theme-name { font-weight:600;font-size:0.95rem; }
    .setup-theme-desc { font-size:0.8rem;color:#64748b; }
    .setup-label { font-size:0.85rem;font-weight:500;color:var(--text-muted,#64748b);margin-bottom:6px;display:block; }
    .setup-input-wrap { position:relative; }
    .setup-input { width:100%;padding:0.6rem 2.5rem 0.6rem 0.85rem;border-radius:8px;border:1.5px solid var(--border-color,#e2e8f0);background:var(--surface-raised,#f8fafc);color:var(--text-main,#111);font-size:0.95rem;outline:none; }
    .setup-input:focus { border-color:#378ADD; }
    .setup-input-toggle { position:absolute;right:0.75rem;top:50%;transform:translateY(-50%);background:none;border:none;color:#94a3b8;cursor:pointer;padding:0; }
    .setup-done-avatar { width:90px;height:90px;border-radius:50%;object-fit:cover;border:3px solid #378ADD;display:block;margin:0 auto; }
    .setup-done-initials { width:90px;height:90px;border-radius:50%;background:#185FA5;color:#fff;display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:700;margin:0 auto; }
    .setup-btn { padding:0.7rem 1.5rem;font-size:0.95rem;border-radius:10px;width:100%; }
    .setup-btn-outline { padding:0.7rem 1.5rem;font-size:0.95rem;border-radius:10px;width:100%;background:transparent;border:1.5px solid #cbd5e1;color:#64748b;cursor:pointer; }
    .setup-nav { display:flex;justify-content:space-between;align-items:center;margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--border-color,#e2e8f0); }
    .setup-back-btn { background:none;border:none;color:#64748b;font-size:0.9rem;cursor:pointer;padding:0.5rem 0; }
    .setup-next-btn { background:#185FA5;color:#fff;border:none;border-radius:10px;padding:0.6rem 1.5rem;font-size:0.9rem;font-weight:500;cursor:pointer; }
    .setup-next-btn:disabled { opacity:0.6;cursor:not-allowed; }
    .setup-skip-link { background:none;border:none;color:#94a3b8;font-size:0.8rem;cursor:pointer;text-decoration:underline; }
</style>

@code {
    private int currentStep = 1;
    private int totalSteps  = 5;
    private string driverName    = "";
    private string userEmail     = "";
    private string companyName   = "your company";
    private string userAuthId    = "";
    private string previewUrl    = "";
    private string finalAvatarUrl = "";
    private string uploadError   = "";
    private bool   isUploading   = false;
    private string selectedTheme = "System";
    private string newPassword    = "";
    private string confirmPassword = "";
    private string passwordError  = "";
    private bool   showPassword   = false;
    private bool   isSaving       = false;

    protected override async Task OnInitializedAsync()
    {
        var session = Supabase.Auth.CurrentSession;
        if (session?.User == null) { Nav.NavigateTo("/"); return; }
        userEmail  = session.User.Email ?? "";
        userAuthId = session.User.Id ?? "";
        try
        {
            var driver = await Supabase.From<FleetManagement.Models.Driver>()
                .Filter("email", Postgrest.Constants.Operator.Equals, userEmail)
                .Single();
            if (driver != null)
            {
                driverName = driver.Name;
                if (driver.HasCompletedSetup)
                {
                    Nav.NavigateTo(driver.Role == "Admin" ? "/admin" : "/driver");
                    return;
                }
            }
        }
        catch { }
        try
        {
            var tenant = await Supabase.From<FleetManagement.Models.TenantSettings>().Single();
            if (tenant != null && !string.IsNullOrEmpty(tenant.CompanyName))
                companyName = tenant.CompanyName;
        }
        catch { }
    }

    private void NextStep() { if (currentStep < totalSteps) currentStep++; }
    private void PrevStep()  { if (currentStep > 1) currentStep--; }
    private void SelectTheme(string theme) { selectedTheme = theme; ThemeService.CurrentTheme = theme == "System" ? "Light" : theme; StateHasChanged(); }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        uploadError = "";
        var file = e.File;
        if (file.Size > 5 * 1024 * 1024) { uploadError = "Image must be under 5 MB."; return; }
        isUploading = true; StateHasChanged();
        try
        {
            var buffer = new byte[file.Size];
            await file.OpenReadStream(5 * 1024 * 1024).ReadAsync(buffer);
            previewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
            var path = $"{userAuthId}/avatar.jpg";
            await Supabase.Storage.From("profile-pictures").Upload(buffer, path, new Supabase.Storage.FileOptions { Upsert = true, ContentType = file.ContentType });
            finalAvatarUrl = Supabase.Storage.From("profile-pictures").GetPublicUrl(path);
        }
        catch (Exception ex) { uploadError = $"Upload failed: {ex.Message}"; previewUrl = ""; }
        finally { isUploading = false; StateHasChanged(); }
    }

    private async Task SavePasswordAndFinish()
    {
        passwordError = "";
        if (newPassword.Length < 8) { passwordError = "Password must be at least 8 characters."; return; }
        if (newPassword != confirmPassword) { passwordError = "Passwords do not match."; return; }
        isSaving = true; StateHasChanged();
        try
        {
            await Supabase.Auth.Update(new Supabase.Gotrue.UserAttributes { Password = newPassword });
            var driver = await Supabase.From<FleetManagement.Models.Driver>()
                .Filter("email", Postgrest.Constants.Operator.Equals, userEmail).Single();
            if (driver != null)
            {
                if (!string.IsNullOrEmpty(finalAvatarUrl)) driver.ProfilePictureUrl = finalAvatarUrl;
                driver.HasCompletedSetup  = true;
                driver.MustChangePassword = false;
                await Supabase.From<FleetManagement.Models.Driver>().Update(driver);
            }
            try
            {
                var settings = await Supabase.From<FleetManagement.Models.UserSettings>()
                    .Filter("user_id", Postgrest.Constants.Operator.Equals, userAuthId).Single();
                if (settings != null) { settings.Theme = selectedTheme; await Supabase.From<FleetManagement.Models.UserSettings>().Update(settings); }
                else await Supabase.From<FleetManagement.Models.UserSettings>().Insert(new FleetManagement.Models.UserSettings { UserId = userAuthId, Theme = selectedTheme });
            }
            catch { }
            currentStep = 5;
        }
        catch (Exception ex) { passwordError = $"Failed to save: {ex.Message}"; }
        finally { isSaving = false; StateHasChanged(); }
    }

    private async Task FinishWithTour()    { await SetTourFlag(false); await RedirectToDashboard(); }
    private async Task FinishWithoutTour() { await SetTourFlag(true);  await RedirectToDashboard(); }

    private async Task SetTourFlag(bool taken)
    {
        try
        {
            var driver = await Supabase.From<FleetManagement.Models.Driver>()
                .Filter("email", Postgrest.Constants.Operator.Equals, userEmail).Single();
            if (driver != null) { driver.HasTakenTour = taken; await Supabase.From<FleetManagement.Models.Driver>().Update(driver); }
        }
        catch { }
    }

    private async Task RedirectToDashboard()
    {
        try
        {
            var driver = await Supabase.From<FleetManagement.Models.Driver>()
                .Filter("email", Postgrest.Constants.Operator.Equals, userEmail).Single();
            Nav.NavigateTo(driver?.Role == "Admin" ? "/admin" : "/driver", forceLoad: true);
        }
        catch { Nav.NavigateTo("/driver", forceLoad: true); }
    }

    private async Task SkipSetup()
    {
        try
        {
            var driver = await Supabase.From<FleetManagement.Models.Driver>()
                .Filter("email", Postgrest.Constants.Operator.Equals, userEmail).Single();
            if (driver != null)
            {
                driver.HasCompletedSetup  = true;
                driver.MustChangePassword = false;
                await Supabase.From<FleetManagement.Models.Driver>().Update(driver);
                Nav.NavigateTo(driver.Role == "Admin" ? "/admin" : "/driver", forceLoad: true);
            }
        }
        catch { Nav.NavigateTo("/driver", forceLoad: true); }
    }
}
