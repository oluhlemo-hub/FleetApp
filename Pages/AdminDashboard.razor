@if (tourActive)
{
    <!-- Tour backdrop -->
    <div style="position:fixed;inset:0;z-index:2000;pointer-events:none;">
        <!-- Dark overlay with hole cut out via box-shadow -->
        <div id="tour-spotlight" style="position:absolute;border-radius:8px;box-shadow:0 0 0 9999px rgba(0,0,0,0.65);transition:all 0.35s ease;pointer-events:none;z-index:2001;"></div>
    </div>

    <!-- Tour tooltip -->
    <div id="tour-tooltip" style="position:fixed;z-index:2002;max-width:320px;min-width:260px;background:var(--card-bg);border:1px solid var(--border-color);border-radius:16px;padding:1.25rem 1.25rem 1rem;box-shadow:0 8px 40px rgba(0,0,0,0.45);transition:all 0.3s ease;top:@tourTooltipTop;left:@tourTooltipLeft;">
        <!-- Progress dots -->
        <div style="display:flex;gap:5px;margin-bottom:0.75rem;">
            @for (int i = 0; i < tourSteps.Count; i++)
            {
                var stepIdx = i;
                <div style="width:@(i == tourStep ? "20px" : "7px");height:7px;border-radius:4px;background:@(i == tourStep ? "var(--accent-primary)" : "var(--border-color)");transition:all 0.3s;"></div>
            }
        </div>

        <!-- Step icon + title -->
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:0.5rem;">
            <div style="width:36px;height:36px;border-radius:10px;background:var(--surface-raised);display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0;">
                @((MarkupString)tourSteps[tourStep].Icon)
            </div>
            <div style="font-weight:700;font-size:0.95rem;color:var(--text-main);">@tourSteps[tourStep].Title</div>
        </div>

        <!-- Description -->
        <p style="font-size:0.83rem;color:var(--text-muted);line-height:1.55;margin:0 0 1rem;">@tourSteps[tourStep].Description</p>

        <!-- Navigation -->
        <div style="display:flex;align-items:center;justify-content:space-between;">
            <span style="font-size:0.75rem;color:var(--text-muted);">@(tourStep + 1) of @tourSteps.Count</span>
            <div style="display:flex;gap:8px;">
                <button style="background:none;border:1px solid var(--border-color);border-radius:8px;padding:6px 14px;font-size:0.8rem;color:var(--text-muted);cursor:pointer;" @onclick="EndTour">Skip</button>
                @if (tourStep > 0)
                {
                    <button style="background:var(--surface-raised);border:none;border-radius:8px;padding:6px 14px;font-size:0.8rem;color:var(--text-main);cursor:pointer;" @onclick="PrevTourStep">Back</button>
                }
                @if (tourStep < tourSteps.Count - 1)
                {
                    <button style="background:var(--accent-primary);border:none;border-radius:8px;padding:6px 16px;font-size:0.8rem;color:#fff;font-weight:600;cursor:pointer;" @onclick="NextTourStep">Next →</button>
                }
                else
                {
                    <button style="background:var(--accent-success);border:none;border-radius:8px;padding:6px 16px;font-size:0.8rem;color:#fff;font-weight:600;cursor:pointer;" @onclick="EndTour">Done ✓</button>
                }
            </div>
        </div>
    </div>

    <!-- Click anywhere to close backdrop -->
    <div style="position:fixed;inset:0;z-index:1999;" @onclick="EndTour"></div>
}

