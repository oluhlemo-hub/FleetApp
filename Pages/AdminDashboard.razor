    private async Task DownloadCsv(string reportType)
    {
        try
        {
            var sb = new System.Text.StringBuilder();
            var fileName = string.Empty;

            switch (reportType)
            {
                case "vehicles":
                    fileName = $"vehicles_{DateTime.Today:yyyyMMdd}.csv";
                    sb.AppendLine("Registration,Make,Model,Status,Mileage,ServiceDueKm,LastDriver,TotalTrips,TotalFaults,TotalFuelLogs");
                    foreach (var v in vehicles)
                    {
                        var trips  = allTripHistory.Count(t => t.VehicleId == v.Id);
                        var faults = allFaults.Count(f => f.VehicleId == v.Id);
                        var fuels  = allFuelLogs.Count(f => f.VehicleId == v.Id);
                        sb.AppendLine($"{v.Registration},{v.Make},{v.Model},{v.Status},{v.Mileage},{v.ServiceDueKm},{v.LastDriver ?? "Unassigned"},{trips},{faults},{fuels}");
                    }
                    break;

                case "drivers":
                    fileName = $"drivers_{DateTime.Today:yyyyMMdd}.csv";
                    sb.AppendLine("Name,Email,Phone,Role,Status,TotalTrips,TotalKm,FaultsReported,CleanReturns,Rating,FuelCard,LastVehicle");
                    foreach (var d in drivers)
                    {
                        var dTrips = allTripHistory.Where(t => t.DriverEmail == d.Email).ToList();
                        var dFaults = allFaults.Count(f => f.DriverEmail == d.Email);
                        var cleanR = dTrips.Count(t => t.ReturnCondition == "Clean" || t.ReturnCondition == "Good");
                        var totalKm = dTrips.Sum(t => t.EndMileage - t.StartMileage);
                        var rating = GetDriverRating(d.Email);
                        sb.AppendLine($"{d.Name},{d.Email},{d.Phone ?? ""},{d.Role},{(d.IsActive ? "Active" : "Inactive")},{dTrips.Count},{totalKm},{dFaults},{cleanR},{rating:0.0},{d.FuelCardNumber ?? ""},{d.LastVehicle ?? ""}");
                    }
                    break;

                case "fuellogs":
                    fileName = $"fuel_logs_{DateTime.Today:yyyyMMdd}.csv";
                    sb.AppendLine("Date,Vehicle,Driver,ExpenseType,FuelType,Litres,Cost,Station,FuelCard,ExpenseCategory");
                    foreach (var l in allFuelLogs.OrderByDescending(x => x.LoggedAt))
                        sb.AppendLine($"{l.LoggedAt.ToLocalTime():dd/MM/yyyy HH:mm},{l.VehicleRegistration},{l.DriverEmail},{l.ExpenseType},{l.FuelType ?? ""},{l.Litres?.ToString("F1") ?? ""},{l.Cost:F2},{l.StationName ?? ""},{l.FuelCardNumber ?? ""},{l.ExpenseCategory ?? ""}");
                    break;

                case "faults":
                    fileName = $"faults_{DateTime.Today:yyyyMMdd}.csv";
                    sb.AppendLine("Date,Vehicle,Driver,FaultType,Description,Status");
                    foreach (var f in allFaults.OrderByDescending(x => x.CreatedAt))
                        sb.AppendLine($"{f.CreatedAt.ToLocalTime():dd/MM/yyyy HH:mm},{f.VehicleRegistration},{f.DriverEmail},{f.FaultType},\"" + f.Description.Replace("\"", "\"\""  ) + "\",{f.Status}");
                    break;

                case "trips":
                    fileName = $"trips_{DateTime.Today:yyyyMMdd}.csv";
                    sb.AppendLine("Date,Driver,DriverEmail,Vehicle,StartMileage,EndMileage,KmDriven,ReturnCondition");
                    foreach (var t in allTripHistory.OrderByDescending(x => x.CreatedAt))
                        sb.AppendLine($"{t.CreatedAt.ToLocalTime():dd/MM/yyyy HH:mm},{t.DriverName},{t.DriverEmail},{t.VehicleRegistration},{t.StartMileage},{t.EndMileage},{t.EndMileage - t.StartMileage},{t.ReturnCondition ?? ""}");
                    break;

                case "services":
                    fileName = $"service_history_{DateTime.Today:yyyyMMdd}.csv";
                    sb.AppendLine("Date,Vehicle,Driver,ServiceStation,MileageAtService,NextServiceKm,ReportUrl");
                    var svcResp = await Supabase.From<ServiceHistory>().Get();
                    foreach (var s in svcResp.Models.OrderByDescending(x => x.ServicedAt))
                        sb.AppendLine($"{s.ServicedAt.ToLocalTime():dd/MM/yyyy HH:mm},{s.VehicleRegistration},{s.DriverEmail},{s.ServiceStation ?? ""},{s.MileageAtService},{s.NextServiceKm},{s.ReportUrl ?? ""}");
                    break;
            }

            var bytes = System.Text.Encoding.UTF8.GetBytes(sb.ToString());
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFile", fileName, "text/csv", base64);
        }
        catch (Exception ex) { successMessage = $"Export failed: {ex.Message}"; }
    }


