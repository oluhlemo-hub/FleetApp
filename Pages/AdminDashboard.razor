@if (activeTab == "documents")
{
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong><i class="bi bi-folder2-open me-2"></i>Vehicle Documents</strong>
        </div>
        <div class="card-body p-0">
            <table class="d-none d-md-table" style="width:100%;border-collapse:collapse;background:var(--card-bg);color:var(--text-main);">
                <thead>
                    <tr style="background:var(--surface-navy);">
                        <th style="color:rgba(255,255,255,0.85);font-size:0.7rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:13px 18px;border:none;">Vehicle</th>
                        <th style="color:rgba(255,255,255,0.85);font-size:0.7rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:13px 18px;border:none;">Document Type</th>
                        <th style="color:rgba(255,255,255,0.85);font-size:0.7rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:13px 18px;border:none;">Expiry Date</th>
                        <th style="color:rgba(255,255,255,0.85);font-size:0.7rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:13px 18px;border:none;">Status</th>
                        <th style="color:rgba(255,255,255,0.85);font-size:0.7rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:13px 18px;border:none;">File</th>
                        <th style="color:rgba(255,255,255,0.85);font-size:0.7rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:13px 18px;border:none;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (vehicleDocs.Any())
                    {
                        @foreach (var doc in vehicleDocs.OrderBy(d => d.ExpiryDate))
                        {
                            var days = (doc.ExpiryDate.Date - DateTime.Today).Days;
                            var badge = days <= 0 ? "bg-danger" : days <= 7 ? "bg-danger" : days <= 14 ? "bg-warning text-dark" : days <= 30 ? "bg-warning text-dark" : "bg-success";
                            var status = days <= 0 ? "Expired" : days <= 7 ? $"{days}d left" : days <= 30 ? $"{days}d left" : "Valid";
                            <tr style="background:var(--card-bg);border-bottom:1px solid var(--border-color);">
                                <td><strong>@doc.VehicleRegistration</strong></td>
                                <td><span class="badge bg-secondary">@doc.DocumentType</span></td>
                                <td>@doc.ExpiryDate.ToString("dd MMM yyyy")</td>
                                <td><span class="badge @badge">@status</span></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(doc.FileUrl))
                                    {
                                        <a href="@doc.FileUrl" target="_blank" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-file-earmark me-1"></i>View
                                        </a>
                                    }
                                    else { <span class="text-muted small">No file</span> }
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteDocument(doc)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-center text-muted py-4">No documents uploaded yet.</td></tr>
                    }
                </tbody>
            </table>
            <div class="d-md-none">
                @foreach (var doc in vehicleDocs.OrderBy(d => d.ExpiryDate))
                {
                    var days = (doc.ExpiryDate.Date - DateTime.Today).Days;
                    var badge = days <= 0 ? "bg-danger" : days <= 14 ? "bg-warning text-dark" : "bg-success";
                    var status = days <= 0 ? "Expired" : days <= 30 ? $"{days} days left" : "Valid";
                    <div class="card shadow-sm mb-3 @(days <= 7 ? "border-danger" : days <= 30 ? "border-warning" : "")">
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-1">
                                <strong>@doc.VehicleRegistration</strong>
                                <span class="badge @badge">@status</span>
                            </div>
                            <div class="small text-muted mb-2">
                                <span class="badge bg-secondary me-1">@doc.DocumentType</span>
                                Expires @doc.ExpiryDate.ToString("dd MMM yyyy")
                            </div>
                            <div class="d-flex gap-2">
                                @if (!string.IsNullOrEmpty(doc.FileUrl))
                                {
                                    <a href="@doc.FileUrl" target="_blank" class="btn btn-sm btn-outline-primary flex-grow-1">
                                        <i class="bi bi-file-earmark me-1"></i>View
                                    </a>
                                }
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteDocument(doc)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                }
                @if (!vehicleDocs.Any())
                {
                    <p class="text-center text-muted py-4">No documents uploaded yet.</p>
                }
            </div>
        </div>
        <div class="card-footer">
            <button class="btn btn-primary" @onclick="() => { isDocModalVisible = true; modalError = string.Empty; modalErrorDetail = string.Empty; }">
                <i class="bi bi-plus-circle me-1"></i> Add Document
            </button>
        </div>
    </div>
}

