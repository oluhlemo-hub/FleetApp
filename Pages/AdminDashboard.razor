                    <div class="mb-3">
                        <label class="form-label">Document File <span class="text-muted small">(optional — PDF or image)</span></label>
                        <InputFile OnChange="OnDocFileSelected" class="form-control" accept=".pdf,.jpg,.jpeg,.png" />
                        @if (!string.IsNullOrEmpty(docFileUrl))
                        {
                            <div class="form-text text-success"><i class="bi bi-check-circle me-1"></i>File uploaded.</div>
