    private async Task OnDocFileSelected(InputFileChangeEventArgs e)
    {
        isUploadingDoc = true;
        modalError = string.Empty; modalErrorDetail = string.Empty;
        try
        {
            var file = e.File;
            var ext = Path.GetExtension(file.Name);
            var fileName = $"docs/{Guid.NewGuid()}{ext}";
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            var bytes = new byte[file.Size];
            await stream.ReadAsync(bytes);
            await Supabase.Storage.From("vehicle-documents").Upload(bytes, fileName,
                new Supabase.Storage.FileOptions { ContentType = file.ContentType, Upsert = true });
            docFileUrl = Supabase.Storage.From("vehicle-documents").GetPublicUrl(fileName);
        }
        catch (Exception ex) { modalError = $"File upload failed: {ex.Message}"; }
        finally { isUploadingDoc = false; StateHasChanged(); }
    }

