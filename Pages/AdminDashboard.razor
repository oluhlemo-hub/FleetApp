                    </div>
                </div>
                <div class="modal-footer flex-column gap-2">
                    <button class="btn btn-primary w-100" @onclick="SaveDocument" disabled="@(isUploadingDoc || string.IsNullOrEmpty(docVehicleId))">
                        <i class="bi bi-save me-1"></i> Save Document
                    </button>
                    <button class="btn btn-secondary w-100" @onclick="() => isDocModalVisible = false">Cancel</button>
                </div>
        </div>
    </div>
