@code {

    private List<Vehicle> vehicles = new();
    private List<Driver> drivers = new();
    private List<Fault> allFaults = new();
    private List<Fault> openFaults = new();
    private List<TripHistory> allTripHistory = new();
    private List<FuelLog> allFuelLogs = new();
    private List<FuelCard> fuelCards = new();
    private List<FleetManagement.Models.VehicleDocument> vehicleDocs = new();

    // Documents modal
    private bool isDocModalVisible = false;
    private string docVehicleId = string.Empty;
    private string docVehicleReg = string.Empty;
    private string docType = "registration";
    private DateTime docExpiryDate = DateTime.Today.AddYears(1);
    private string docFileUrl = string.Empty;
    private bool isUploadingDoc = false;

    // Expiry alerts
    private List<FleetManagement.Models.VehicleDocument> expiringDocs = new();

    // Fuel Card Modal
    private bool isFuelCardModalVisible = false;
    private bool isSubmittingCard = false;
    private string newFuelCardNumber = string.Empty;
    private string newFuelCardProvider = string.Empty;

    private Vehicle newVehicle = new() { Status = "Available" };
    private Vehicle? selectedVehicle = null;
    private Driver? selectedDriver = null;
    private Fault? selectedFault = null;

    private bool showConfirmModal = false;
    private string confirmTitle = "";
    private string confirmMessage = "";
    private Func<Task>? confirmAction = null;

    private DriverFormModel driverForm = new();
    private string tempPassword = "";
    private bool isVehicleModalVisible = false;
    private bool isDriverModalVisible = false;
    private bool showNotifications = false;
    private List<(string DriverName, string DriverEmail, string VehicleReg, int Mileage)> mileageAlerts = new();
    private string modalError = "";
    private string successMessage = "";
    private string activeTab = "vehicles";

    // Vehicle History
    private bool showVehicleHistory = false;
    private Vehicle? vehicleHistoryTarget = null;
    private List<ServiceHistory> vehicleServiceHistory = new();
    private List<TripHistory> vehicleTripHistory = new();
    private List<Fault> vehicleFaultHistory = new();

    // Driver Profile
    private bool showDriverProfile = false;
    private Driver? driverProfileTarget = null;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadMileageAlerts()
    {
        try
        {
            var cutoff = DateTime.UtcNow.AddMinutes(-2); // Change to AddHours(-12) for production
            var vehicles = await Supabase.From<Vehicle>()
                .Filter("status", Postgrest.Constants.Operator.Equals, "Active")
                .Get();
            var activeVehicles = vehicles.Models.Where(v => !string.IsNullOrEmpty(v.LastDriver)).ToList();

            var drivers = await Supabase.From<Driver>().Get();
            var trips = await Supabase.From<TripHistory>().Get();
            var recentDrivers = trips.Models
                .Where(t => t.CreatedAt >= cutoff)
                .Select(t => t.DriverEmail)
                .ToHashSet();

            mileageAlerts = new();
            foreach (var vehicle in activeVehicles)
            {
                var driver = drivers.Models.FirstOrDefault(d =>
                    d.Name == vehicle.LastDriver || d.Email == vehicle.LastDriver);
                if (driver == null) continue;
                if (recentDrivers.Contains(driver.Email)) continue;
                mileageAlerts.Add((driver.Name, driver.Email, vehicle.Registration, vehicle.Mileage));
            }
        }
        catch { }
    }

    private async Task LoadData()
    {
        await LoadMileageAlerts();
        try
        {
            var vehicleResponse = await Supabase.From<Vehicle>().Get();
            vehicles = vehicleResponse.Models;

            var driverResponse = await Supabase.From<Driver>().Get();
            drivers = driverResponse.Models;

            var faultResponse = await Supabase.From<Fault>().Get();
            allFaults = faultResponse.Models;
            openFaults = allFaults.Where(f => f.Status == "Open").ToList();

            var tripResponse = await Supabase.From<TripHistory>().Get();
            allTripHistory = tripResponse.Models;

            var fuelLogResponse = await Supabase.From<FuelLog>().Get();
            allFuelLogs = fuelLogResponse.Models;

            var fuelCardResponse = await Supabase.From<FuelCard>().Get();
            fuelCards = fuelCardResponse.Models;

            await LoadDocuments();
        }
        catch (Exception)
        {
            successMessage = "Failed to load data. Please refresh the page.";
        }
    }

    private async Task OpenFuelCardModal()
    {
        await LoadFuelCards();
        isFuelCardModalVisible = true;
        modalError = string.Empty;
    }

    // ── Vehicle History ──────────────────────────────────────
    private async Task OpenVehicleHistory(Vehicle car)
    {
        vehicleHistoryTarget = car;
        showVehicleHistory = true;

        try
        {
            var svcResp = await Supabase.From<ServiceHistory>()
                .Filter("vehicle_id", Postgrest.Constants.Operator.Equals, car.Id)
                .Get();
            vehicleServiceHistory = svcResp.Models;

            vehicleTripHistory = allTripHistory
                .Where(t => t.VehicleId == car.Id)
                .ToList();

            vehicleFaultHistory = allFaults
                .Where(f => f.VehicleId == car.Id)
                .ToList();
        }
        catch { vehicleServiceHistory = new(); vehicleTripHistory = new(); vehicleFaultHistory = new(); }
    }

    private void CloseVehicleHistory()
    {
        showVehicleHistory = false;
        vehicleHistoryTarget = null;
    }

    // ── Driver Profile ───────────────────────────────────────
    private void OpenDriverProfile(Driver driver)
    {
        driverProfileTarget = driver;
        showDriverProfile = true;
    }

    private void CloseDriverProfile()
    {
        showDriverProfile = false;
        driverProfileTarget = null;
    }

    // ── Driver Rating ────────────────────────────────────────
    // Rating out of 5:
    //   Base score: 5
    //   -0.5 per fault (min 0 deduction from faults)
    //   +bonus for clean/good returns (up to 1 point)
    private double GetDriverRating(string driverEmail)
    {
        var driverFaults = allFaults.Count(f => f.DriverEmail == driverEmail);
        var driverTrips  = allTripHistory.Where(t => t.DriverEmail == driverEmail).ToList();

        double score = 5.0;
        score -= driverFaults * 0.5;

        if (driverTrips.Any())
        {
            var cleanRatio = (double)driverTrips.Count(t => t.ReturnCondition == "Clean" || t.ReturnCondition == "Good")
                             / driverTrips.Count;
            // dirty returns penalise up to -1
            score -= (1 - cleanRatio) * 1.0;
        }

        return Math.Max(0, Math.Min(5, Math.Round(score * 2) / 2)); // snap to 0.5 steps
    }

    private string RenderStars(double rating)
    {
        var stars = "";
        for (int i = 1; i <= 5; i++)
        {
            if (rating >= i)
                stars += "★";
            else if (rating >= i - 0.5)
                stars += "½";
            else
                stars += "☆";
        }
        return stars;
    }

