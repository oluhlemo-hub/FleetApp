<!-- VEHICLE HISTORY MODAL                              -->
<!-- ══════════════════════════════════════════════════ -->
@if (showVehicleHistory && vehicleHistoryTarget != null)
{
    <div class="modal-backdrop-panel" @onclick="CloseVehicleHistory">
        <div class="modal-card-panel" @onclick:stopPropagation="true">
            <div class="p-4 border-bottom">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h5 class="mb-0 fw-bold"><i class="bi bi-clock-history me-2 text-primary"></i>Vehicle History</h5>
                        <span class="text-muted small">@vehicleHistoryTarget.Make @vehicleHistoryTarget.Model — @vehicleHistoryTarget.Registration</span>
                    </div>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CloseVehicleHistory"><i class="bi bi-x-lg"></i></button>
                </div>
            </div>

            <div class="modal-card-panel-body">

                <!-- Stats -->
                <div class="row g-3 mb-4">
                    <div class="col-3">
                        <div class="text-center p-3 rounded-3 bg-primary bg-opacity-10">
                            <div class="fs-4 fw-bold text-primary">@vehicleServiceHistory.Count</div>
                            <div class="small text-muted">Services</div>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="text-center p-3 rounded-3 bg-danger bg-opacity-10">
                            <div class="fs-4 fw-bold text-danger">@vehicleFaultHistory.Count</div>
                            <div class="small text-muted">Faults</div>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="text-center p-3 rounded-3 bg-success bg-opacity-10">
                            <div class="fs-4 fw-bold text-success">@vehicleTripHistory.Count</div>
                            <div class="small text-muted">Trips</div>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="text-center p-3 rounded-3 bg-warning bg-opacity-10">
                            <div class="fs-4 fw-bold text-warning">@allFuelLogs.Count(f => f.VehicleId == vehicleHistoryTarget!.Id)</div>
                            <div class="small text-muted">Fuel Logs</div>
                        </div>
                    </div>
                </div>

                <!-- Service History -->
                <h6 class="fw-bold mb-3"><i class="bi bi-tools me-2 text-primary"></i>Service History</h6>
                @if (vehicleServiceHistory.Any())
                {
                    @foreach (var svc in vehicleServiceHistory.OrderByDescending(s => s.ServicedAt))
                    {
                        <div class="card border-0 mb-2" style="background:var(--card-bg);border:1px solid var(--border-color) !important;">
                            <div class="card-body py-2 px-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="fw-semibold small" style="color:var(--text-main);">@(svc.ServiceStation ?? "Unknown station")</div>
                                        <div class="text-muted x-small">By @svc.DriverEmail</div>
                                    </div>
                                    <div class="text-end">
                                        <div class="small fw-semibold" style="color:var(--text-main);">@svc.MileageAtService km</div>
                                        <div class="text-muted x-small">@svc.ServicedAt.ToLocalTime().ToString("dd MMM yyyy")</div>
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(svc.ReportUrl))
                                {
                                    <div class="mt-2">
                                        <a href="@svc.ReportUrl" target="_blank" class="btn btn-sm btn-outline-primary py-0 px-2" style="font-size:0.75rem;">
                                            <i class="bi bi-file-earmark-text me-1"></i>View Service Report
                                        </a>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small mb-4">No service records yet.</p>
                }

                <!-- Trip / Driver History -->
                <h6 class="fw-bold mb-3 mt-4"><i class="bi bi-people me-2 text-success"></i>Driver Usage History</h6>
                @if (vehicleTripHistory.Any())
                {
                    @foreach (var trip in vehicleTripHistory.OrderByDescending(t => t.CreatedAt))
                    {
                        <div class="card border-0 bg-light mb-2">
                            <div class="card-body py-2 px-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="fw-semibold small">@trip.DriverName</div>
                                        <div class="text-muted x-small">@trip.DriverEmail</div>
                                        @if (!string.IsNullOrEmpty(trip.ReturnCondition))
                                        {
                                            <span class="badge @GetConditionBadge(trip.ReturnCondition) mt-1">
                                                Returned: @trip.ReturnCondition
                                            </span>
                                        }
                                    </div>
                                    <div class="text-end">
                                        <div class="small fw-semibold">+@(trip.EndMileage - trip.StartMileage) km</div>
                                        <div class="text-muted x-small">@trip.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small mb-4">No trip records yet.</p>
                }


                <!-- Fuel Log History -->
                <h6 class="fw-bold mb-3 mt-4"><i class="bi bi-fuel-pump me-2 text-warning"></i>Fuel Log History</h6>
                @{
                    var vehicleFuelHistory = allFuelLogs
                        .Where(f => f.VehicleId == vehicleHistoryTarget.Id)
                        .OrderByDescending(f => f.LoggedAt).ToList();
                }
                @if (vehicleFuelHistory.Any())
                {
                    @foreach (var log in vehicleFuelHistory)
                    {
                        <div class="card border-0 bg-light mb-2">
                            <div class="card-body py-2 px-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        @if (log.ExpenseType == "Fuel")
                                        {
                                            <span class="badge bg-warning text-dark me-1">@log.FuelType</span>
                                            <span class="small fw-semibold">@($"{log.Litres:F1} L") · R @log.Cost.ToString("F2")</span>
                                            @if (log.MileageKm.HasValue)
                                            { <div class="text-muted x-small">Mileage: @log.MileageKm km</div> }
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary me-1">@log.ExpenseCategory</span>
                                            <span class="small fw-semibold">R @log.Cost.ToString("F2")</span>
                                        }
                                        <div class="text-muted x-small">@log.DriverEmail</div>
                                    </div>
                                    <div class="text-end">
                                        <div class="text-muted x-small">@log.LoggedAt.ToLocalTime().ToString("dd MMM yyyy")</div>
                                        @if (!string.IsNullOrEmpty(log.ReceiptUrl))
                                        {
                                            <a href="@log.ReceiptUrl" target="_blank" class="btn btn-sm btn-link p-0 small">Receipt</a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small">No fuel logs recorded.</p>
                }
                <!-- Fault History -->
                <h6 class="fw-bold mb-3 mt-4"><i class="bi bi-exclamation-triangle me-2 text-danger"></i>Fault History</h6>
                @if (vehicleFaultHistory.Any())
                {
                    @foreach (var fault in vehicleFaultHistory.OrderByDescending(f => f.CreatedAt))
                    {
                        <div class="card border-0 bg-light mb-2">
                            <div class="card-body py-2 px-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <span class="badge bg-warning text-dark me-1">@fault.FaultType</span>
                                        <span class="badge @(fault.Status == "Open" ? "bg-danger" : "bg-success")">@fault.Status</span>
                                        <div class="text-muted x-small mt-1">@fault.DriverEmail</div>
                                    </div>
                                    <div class="text-muted x-small">@fault.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</div>
                                </div>
                                <div class="small mt-1 text-truncate">@fault.Description</div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small">No faults recorded.</p>
                }
            </div>
        </div>
    </div>
}

<!-- ══════════════════════════════════════════════════ -->
<!-- DRIVER PROFILE MODAL                               -->
<!-- ══════════════════════════════════════════════════ -->
@if (showDriverProfile && driverProfileTarget != null)
{
    <div class="modal-backdrop-panel" @onclick="CloseDriverProfile">
        <div class="modal-card-panel" @onclick:stopPropagation="true">
            <div class="p-4 border-bottom">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center gap-3">
                        <div class="driver-avatar">
                            <i class="bi bi-person-circle fs-1 text-secondary"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold">@driverProfileTarget.Name</h5>
                            <span class="badge @(driverProfileTarget.Role == "Admin" ? "bg-warning text-dark" : "bg-info text-dark")">
                                @driverProfileTarget.Role
                            </span>
                        </div>
                    </div>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CloseDriverProfile"><i class="bi bi-x-lg"></i></button>
                </div>
            </div>

            <div class="modal-card-panel-body">

                <!-- Contact Info -->
                <h6 class="fw-bold mb-3"><i class="bi bi-person-lines-fill me-2 text-primary"></i>Contact Info</h6>
                <div class="card border-0 bg-light mb-4">
                    <div class="card-body py-2 px-3">
                        <div class="d-flex justify-content-between py-1 border-bottom">
                            <span class="text-muted small">Email</span>
                            <span class="small fw-semibold">@driverProfileTarget.Email</span>
                        </div>
                        <div class="d-flex justify-content-between py-1 border-bottom">
                            <span class="text-muted small">Phone</span>
                            <span class="small fw-semibold">@(string.IsNullOrEmpty(driverProfileTarget.Phone) ? "—" : driverProfileTarget.Phone)</span>
                        </div>
                        <div class="d-flex justify-content-between py-1">
                            <span class="text-muted small">Status</span>
                            <span class="badge @(driverProfileTarget.IsActive ? "bg-success" : "bg-secondary")">
                                @(driverProfileTarget.IsActive ? "Active" : "Inactive")
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Rating -->
                <h6 class="fw-bold mb-3"><i class="bi bi-star-fill me-2 text-warning"></i>Driver Rating</h6>
                <div class="card border-0 bg-light mb-4">
                    <div class="card-body py-3 px-3">
                        @{
                            var rating = GetDriverRating(driverProfileTarget.Email);
                            var driverFaultCount = allFaults.Count(f => f.DriverEmail == driverProfileTarget.Email);
                            var driverTrips = allTripHistory.Where(t => t.DriverEmail == driverProfileTarget.Email).ToList();
                            var cleanReturns = driverTrips.Count(t => t.ReturnCondition == "Clean" || t.ReturnCondition == "Good");
                        }
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="fs-4">@RenderStars(rating)</span>
                            <span class="fw-bold fs-5">@rating.ToString("0.0") / 5.0</span>
                        </div>
                        <div class="row g-2 mt-1">
                            <div class="col-6">
                                <div class="small text-muted">Faults reported</div>
                                <div class="fw-semibold @(driverFaultCount > 3 ? "text-danger" : "text-success")">
                                    @driverFaultCount fault@(driverFaultCount == 1 ? "" : "s")
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="small text-muted">Clean returns</div>
                                <div class="fw-semibold text-success">@cleanReturns / @driverTrips.Count</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Stats -->
                <div class="row g-3 mb-4">
                    <div class="col-4">
                        <div class="text-center p-3 rounded-3 bg-primary bg-opacity-10">
                            <div class="fs-4 fw-bold text-primary">@driverTrips.Count</div>
                            <div class="small text-muted">Trips</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="text-center p-3 rounded-3 bg-danger bg-opacity-10">
                            <div class="fs-4 fw-bold text-danger">@driverFaultCount</div>
                            <div class="small text-muted">Faults</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="text-center p-3 rounded-3 bg-success bg-opacity-10">
                            <div class="fs-4 fw-bold text-success">
                                @(driverTrips.Sum(t => t.EndMileage - t.StartMileage)) km
                            </div>
                            <div class="small text-muted">Total km</div>
                        </div>
                    </div>
                </div>

                <!-- Trip History -->
                <h6 class="fw-bold mb-3"><i class="bi bi-car-front me-2 text-success"></i>Vehicle Usage History</h6>
                @if (driverTrips.Any())
                {
                    @foreach (var trip in driverTrips.OrderByDescending(t => t.CreatedAt))
                    {
                        <div class="card border-0 bg-light mb-2">
                            <div class="card-body py-2 px-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="fw-semibold small">@trip.VehicleRegistration</div>
                                        @if (!string.IsNullOrEmpty(trip.ReturnCondition))
                                        {
                                            <span class="badge @GetConditionBadge(trip.ReturnCondition) mt-1">
                                                @trip.ReturnCondition
                                            </span>
                                        }
                                    </div>
                                    <div class="text-end">
                                        <div class="small fw-semibold">+@(trip.EndMileage - trip.StartMileage) km</div>
                                        <div class="text-muted x-small">@trip.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small mb-4">No trips recorded yet.</p>
                }

                <!-- Fault History -->
                <h6 class="fw-bold mb-3 mt-2"><i class="bi bi-exclamation-triangle me-2 text-danger"></i>Fault History</h6>
                @{
                    var driverFaults = allFaults.Where(f => f.DriverEmail == driverProfileTarget.Email)
                                                .OrderByDescending(f => f.CreatedAt).ToList();
                }
                @if (driverFaults.Any())
                {
                    @foreach (var fault in driverFaults)
                    {
                        <div class="card border-0 bg-light mb-2">
                            <div class="card-body py-2 px-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <span class="badge bg-warning text-dark me-1">@fault.FaultType</span>
                                        <span class="badge @(fault.Status == "Open" ? "bg-danger" : "bg-success")">@fault.Status</span>
                                        <div class="small mt-1 text-truncate" style="max-width:220px">@fault.Description</div>
                                    </div>
                                    <div class="text-muted x-small">@fault.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small">No faults reported.</p>
                }
            </div>
        </div>
    </div>
}

<style>
    body { background: #f5f7fa !important; }

    /* ── Stat cards ── */
    .fleet-stat-row {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 10px;
        margin-bottom: 1rem;
    }
    .fleet-stat-card {
        background: var(--card-bg);
        border-radius: 12px;
        border: 1px solid var(--border-color);
        padding: 0.75rem 1rem;
        box-shadow: var(--shadow-card);
        transition: background 0.25s, border-color 0.25s;
    }
    .fleet-stat-accent {
        width: 24px;
        height: 3px;
        border-radius: 2px;
        margin-bottom: 0.5rem;
    }
    .fleet-stat-num {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-main);
        line-height: 1;
        margin-bottom: 0.25rem;
    }
    .fleet-stat-lbl {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    /* ── Mobile responsive ── */
    @@media (max-width: 767px) {
        .fleet-stat-row { grid-template-columns: repeat(2, 1fr); }
        .fleet-stat-row .fleet-stat-card:last-child { grid-column: span 2; }

        .page-header { flex-direction: column; align-items: flex-start; padding: 0.6rem 0.75rem; margin: -0.5rem -0.5rem 0.75rem -0.5rem; }
        .page-header h3 { font-size: 1rem; }
        .header-actions { width: 100%; overflow-x: auto; flex-wrap: nowrap; padding-bottom: 2px; -webkit-overflow-scrolling: touch; }
        .header-actions .btn { font-size: 0.78rem; padding: 5px 10px; white-space: nowrap; flex-shrink: 0; }
        .header-actions .btn span { display: inline !important; }

        .nav-tabs { font-size: 0.78rem; }
        .nav-tabs .nav-link { padding: 6px 10px; }
        .nav-tabs .nav-link i { display: none; }

        .fleet-table thead { display: none; }
        .fleet-table tbody tr { display: block; border: 1px solid var(--border-color); border-radius: 10px; margin-bottom: 10px; padding: 8px 12px; background: var(--card-bg); }
        .fleet-table tbody td { display: flex; justify-content: space-between; align-items: center; padding: 5px 0; border: none; font-size: 0.82rem; }
        .fleet-table tbody td::before { content: attr(data-label); font-size: 0.7rem; font-weight: 700; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.05em; margin-right: 8px; flex-shrink: 0; }
        .fleet-table tbody td:last-child { padding-top: 8px; border-top: 1px solid var(--border-color); margin-top: 4px; justify-content: flex-end; }

        .notifications-panel { position: fixed !important; top: 56px !important; left: 8px !important; right: 8px !important; width: auto !important; z-index: 1050; }
    }
    @@media (max-width: 480px) {
        .fleet-stat-num { font-size: 1.25rem; }
        .fleet-stat-lbl { font-size: 0.68rem; }
        .fleet-stat-card { padding: 0.6rem 0.75rem; }
    }


    /* ── Page layout ── */
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.5rem;
        background: var(--card-bg);
        border-bottom: 1px solid var(--border-color);
        padding: 0.75rem 1rem;
        margin: -0.5rem -0.75rem 1rem -0.75rem;
        transition: background 0.25s;
    }
    .page-header h3 {
        color: var(--text-main);
        font-size: 1.1rem;
        font-weight: 500;
    }
    .header-actions {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    /* ── Buttons ── */
    .btn-primary {
        background: #185FA5 !important;
        border-color: #185FA5 !important;
        color: #ffffff !important;
        border-radius: 8px !important;
    }
    .btn-primary:hover { background: #042C53 !important; border-color: #042C53 !important; }
    .btn-secondary {
        background: #042C53 !important;
        border-color: #042C53 !important;
        color: #B5D4F4 !important;
        border-radius: 8px !important;
    }
    .btn-secondary:hover { background: #185FA5 !important; border-color: #185FA5 !important; }
    .btn-outline-secondary {
        border-color: #B5D4F4 !important;
        color: #185FA5 !important;
        border-radius: 8px !important;
    }
    .btn-outline-secondary:hover { background: var(--surface-raised) !important; }
    .btn-warning {
        background: #BA7517 !important;
        border-color: #BA7517 !important;
        color: #ffffff !important;
        border-radius: 8px !important;
    }
    .btn-warning:hover { background: #854F0B !important; }
    .btn-outline-primary {
        border-color: #185FA5 !important;
        color: #185FA5 !important;
        border-radius: 8px !important;
    }
    .btn-outline-primary:hover { background: var(--surface-raised) !important; }
    .btn-danger { border-radius: 8px !important; }
    .btn-success { border-radius: 8px !important; }

    /* ── Nav tabs ── */
    .nav-tabs {
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        border-bottom: 2px solid var(--border-color) !important;
        gap: 2px;
    }
    .nav-tabs::-webkit-scrollbar { display: none; }
    .nav-tabs .nav-link {
        color: var(--text-muted) !important;
        border: none !important;
        border-bottom: 2px solid transparent !important;
        border-radius: 0 !important;
        padding: 0.5rem 0.85rem;
        font-size: 0.875rem;
        font-weight: 400;
        margin-bottom: -2px;
    }
    .nav-tabs .nav-link:hover { color: var(--accent-primary) !important; background: var(--surface-raised) !important; }
    .nav-tabs .nav-link.active {
        color: var(--accent-primary) !important;
        font-weight: 600;
        border-bottom: 2px solid var(--accent-primary) !important;
        background: transparent !important;
    }

    /* ── Badges ── */
    .badge.bg-secondary { background: #E6F1FB !important; color: #185FA5 !important; }
    .badge.bg-success { background: #EAF3DE !important; color: #3B6D11 !important; }
    .badge.bg-danger { background: #FCEBEB !important; color: #A32D2D !important; }
    .badge.bg-warning { background: #FAEEDA !important; color: #854F0B !important; }
    .badge.bg-primary { background: #E6F1FB !important; color: #042C53 !important; }

    /* ── Cards ── */
    .card {
        border: 1px solid var(--border-color) !important;
        border-radius: 12px !important;
        background: var(--card-bg) !important;
        box-shadow: var(--shadow-card) !important;
    }
    .card-header {
        background: var(--surface-raised) !important;
        border-bottom: 1px solid var(--border-color) !important;
        color: var(--text-main) !important;
        font-weight: 500;
    }

    /* ── Table ── */
    .table thead th {
        background: var(--surface-navy) !important;
        color: rgba(255,255,255,0.9) !important;
        font-weight: 700;
        font-size: 0.72rem;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        border: none !important;
        padding: 13px 16px !important;
    }
    .table tbody td {
        color: var(--text-main) !important;
        border-color: var(--border-color) !important;
        padding: 12px 16px !important;
        vertical-align: middle;
    }
    .table tbody tr { background: var(--card-bg) !important; }
    .table tbody tr:nth-child(even) { background: var(--card-bg-raised) !important; }
    .table tbody tr:hover { background: var(--surface-raised) !important; }
    .table { background: var(--card-bg) !important; }
    .table { border-radius: 8px; overflow: hidden; }

    /* ── Alerts ── */
    .alert-success { background: #EAF3DE !important; border-color: #C0DD97 !important; color: #3B6D11 !important; border-radius: 10px !important; }
    .alert-danger { background: #FCEBEB !important; border-color: #F09595 !important; color: #A32D2D !important; border-radius: 10px !important; }
    .alert-warning { background: #FAEEDA !important; border-color: #FAC775 !important; color: #854F0B !important; border-radius: 10px !important; }

    /* ── Notifications panel ── */
    .notifications-panel {
        position: absolute;
        top: calc(100%% + 8px);
        right: 0;
        width: 360px;
        border-radius: 12px !important;
        z-index: 1000;
        background: var(--card-bg) !important;
        border: 1px solid var(--border-color) !important;
        box-shadow: var(--shadow-elevated) !important;
    }
    .notification-item:hover { background: var(--surface-raised) !important; }

    /* ── Form controls ── */
    .form-control:focus, .form-select:focus {
        border-color: #378ADD !important;
        box-shadow: 0 0 0 2px rgba(55,138,221,0.15) !important;
    }
    .form-control, .form-select {
        border-color: var(--input-border) !important;
        background-color: var(--input-bg) !important;
        color: var(--text-main) !important;
        border-radius: 8px !important;
    }

    /* ── Misc ── */
