    private async Task StartTour()
    {
        tourStep = 0;
        tourActive = true;
        StateHasChanged();
        await Task.Delay(100);
        await PositionTooltip();
    }

    private async Task NextTourStep()
    {
        if (tourStep < tourSteps.Count - 1)
        {
            tourStep++;
            StateHasChanged();
            await Task.Delay(100);
            await PositionTooltip();
        }
    }

    private async Task PrevTourStep()
    {
        if (tourStep > 0)
        {
            tourStep--;
            StateHasChanged();
            await Task.Delay(100);
            await PositionTooltip();
        }
    }

    private void EndTour()
    {
        tourActive = false;
        StateHasChanged();
    }

    private async Task PositionTooltip()
    {
        try
        {
            var step = tourSteps[tourStep];
            var rect = await JS.InvokeAsync<JsonElement>("eval",
                $"(function(){{ var el = document.getElementById('{step.TargetId}'); if(!el) return null; var r = el.getBoundingClientRect(); return {{top:r.top, left:r.left, width:r.width, height:r.height, bottom:r.bottom, right:r.right}}; }})()");

            if (rect.ValueKind == JsonValueKind.Null) return;

            double top = rect.GetProperty("top").GetDouble();
            double left = rect.GetProperty("left").GetDouble();
            double width = rect.GetProperty("width").GetDouble();
            double height = rect.GetProperty("height").GetDouble();
            double bottom = rect.GetProperty("bottom").GetDouble();

            // Position spotlight
            await JS.InvokeVoidAsync("eval",
                $"(function(){{ var el = document.getElementById('tour-spotlight'); if(el){{ el.style.top='{top - 6}px'; el.style.left='{left - 6}px'; el.style.width='{width + 12}px'; el.style.height='{height + 12}px'; }} }})()");

            // Position tooltip below element
            double ttTop = bottom + 14;
            double ttLeft = Math.Max(10, left + width / 2 - 160);

            // If too close to bottom, show above
            if (ttTop + 220 > 900) ttTop = top - 230;

            tourTooltipTop = $"{ttTop}px";
            tourTooltipLeft = $"{ttLeft}px";
            StateHasChanged();
        }
        catch { }
    }

}