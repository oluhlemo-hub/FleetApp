    private async Task LoadDocuments()
    {
        try
        {
            var resp = await Supabase.From<FleetManagement.Models.VehicleDocument>().Get();
            vehicleDocs = resp.Models;
            var today = DateTime.Today;
            expiringDocs = vehicleDocs
                .Where(d => (d.ExpiryDate.Date - today).Days <= 30)
                .OrderBy(d => d.ExpiryDate)
                .ToList();
        }
        catch { vehicleDocs = new(); expiringDocs = new(); }
    }

    private void OnDocVehicleChanged()
    {
        var v = vehicles.FirstOrDefault(x => x.Id == docVehicleId);
        docVehicleReg = v?.Registration ?? string.Empty;
    }

    private async Task OnDocFileSelected(InputFileChangeEventArgs e)
    {
        isUploadingDoc = true;
        modalError = string.Empty;
        try
        {
            var file = e.File;
            var ext = Path.GetExtension(file.Name);
            var fileName = $"docs/{Guid.NewGuid()}{ext}";
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            var bytes = new byte[file.Size];
            await stream.ReadAsync(bytes);
            await Supabase.Storage.From("documents").Upload(bytes, fileName,
                new Supabase.Storage.FileOptions { ContentType = file.ContentType, Upsert = true });
            docFileUrl = Supabase.Storage.From("documents").GetPublicUrl(fileName);
        }
        catch (Exception ex) { modalError = $"File upload failed: {ex.Message}"; }
        finally { isUploadingDoc = false; StateHasChanged(); }
    }

    private async Task SaveDocument()
    {
        if (string.IsNullOrEmpty(docVehicleId)) { modalError = "Please select a vehicle."; return; }
        modalError = string.Empty;
        try
        {
            var doc = new FleetManagement.Models.VehicleDocument
            {
                Id = Guid.NewGuid().ToString(),
                VehicleId = docVehicleId,
                VehicleRegistration = docVehicleReg,
                DocumentType = docType,
                FileUrl = string.IsNullOrEmpty(docFileUrl) ? null : docFileUrl,
                ExpiryDate = docExpiryDate,
                UploadedBy = string.Empty,
                CreatedAt = DateTime.UtcNow
            };
            await Supabase.From<FleetManagement.Models.VehicleDocument>().Insert(doc);
            await LoadDocuments();
            isDocModalVisible = false;
            docVehicleId = string.Empty;
            docVehicleReg = string.Empty;
            docFileUrl = string.Empty;
            docExpiryDate = DateTime.Today.AddYears(1);
            successMessage = "✓ Document saved successfully.";
        }
        catch (Exception ex) { modalError = $"Could not save document: {ex.Message}"; }
    }

    private async Task DeleteDocument(FleetManagement.Models.VehicleDocument doc)
    {
        try
        {
            await Supabase.From<FleetManagement.Models.VehicleDocument>()
                .Where(d => d.Id == doc.Id).Delete();
            await LoadDocuments();
            successMessage = "Document removed.";
        }
        catch { }
    }

