<!-- FUEL CARD MANAGEMENT MODAL -->
@if (isFuelCardModalVisible)
{
    <div class="modal-backdrop-custom">
        <div class="modal-card" style="max-width:680px;">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h5 class="mb-0" style="color:var(--text-main);"><i class="bi bi-credit-card me-2 text-warning"></i>Fuel Card Management</h5>
                    <button class="btn-close" @onclick="() => isFuelCardModalVisible = false"></button>
                </div>
                <div>
                    @if (!string.IsNullOrEmpty(modalError))
                    {
                        <div class="alert alert-danger py-2 d-flex align-items-center gap-2">@modalError @if (!string.IsNullOrEmpty(modalErrorDetail)) { <span title="@modalErrorDetail" style="cursor:help;font-size:1rem;">ℹ️</span> }</div>
                    }
                    <!-- Add new card form -->
                    <div class="card border-0 bg-light mb-3">
                        <div class="card-body">
                            <h6 class="fw-bold mb-3"><i class="bi bi-plus-circle me-2"></i>Add New Fuel Card</h6>
                            <div class="row g-2">
                                <div class="col-12 col-sm-5">
                                    <input class="form-control" @bind="newFuelCardNumber" placeholder="Card number e.g. 4567-8901" />
                                </div>
                                <div class="col-12 col-sm-4">
                                    <input class="form-control" @bind="newFuelCardProvider" placeholder="Provider e.g. Shell, BP" />
                                </div>
                                <div class="col-12 col-sm-3">
                                    <button class="btn btn-warning w-100" @onclick="AddFuelCard" disabled="@isSubmittingCard">
                                        @if (isSubmittingCard) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                        <i class="bi bi-plus-lg me-1"></i> Add Card
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Card list -->
                    @if (fuelCards.Any())
                    {
                        <table class="table table-hover mb-0" style="color:var(--text-main);">
                            <thead style="background:var(--surface-navy);">
                                <tr><th>Card Number</th><th>Provider</th><th>Assigned Driver</th><th>Status</th><th></th></tr>
                            </thead>
                            <tbody>
                                @foreach (var card in fuelCards)
                                {
                                    <tr>
                                        <td class="fw-semibold">@card.CardNumber</td>
                                        <td>@(string.IsNullOrEmpty(card.Provider) ? "—" : card.Provider)</td>
                                        <td>@if (string.IsNullOrEmpty(card.AssignedDriverEmail)) { <span class="text-muted">Unassigned</span> } else { @card.AssignedDriverEmail }</td>
                                        <td><span class="badge @(card.IsActive ? "bg-success" : "bg-secondary")">@(card.IsActive ? "Active" : "Inactive")</span></td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeactivateFuelCard(card)" disabled="@(!card.IsActive)">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-center text-muted py-3">No fuel cards added yet.</p>
                    }
                </div>
                <div class="mt-3">
                    <button class="btn btn-secondary w-100" @onclick="() => isFuelCardModalVisible = false">Close</button>
                </div>
        </div>
    </div>
}

<!-- ADD DOCUMENT MODAL -->
