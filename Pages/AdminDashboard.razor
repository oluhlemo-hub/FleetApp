@page "/admin"
@using FleetManagement.Models
@inject Supabase.Client Supabase
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Forms
@inject Microsoft.AspNetCore.Components.NavigationManager NavigationManager

<AuthGuard RequiredRole="Admin">

<div class="container-fluid px-2 px-md-3">

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible mt-2">
            @successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = string.Empty"></button>
        </div>
    }

    @foreach (var doc in expiringDocs)
    {
        var daysLeft = (doc.ExpiryDate.Date - DateTime.Today).Days;
        var alertClass = daysLeft <= 0 ? "alert-danger" : daysLeft <= 7 ? "alert-danger" : daysLeft <= 14 ? "alert-warning" : "alert-warning";
        var icon = daysLeft <= 7 ? "bi-exclamation-octagon-fill" : "bi-exclamation-triangle-fill";
        var label = daysLeft <= 0 ? "EXPIRED" : daysLeft == 1 ? "expires tomorrow" : $"expires in {daysLeft} days";
        <div class="alert @alertClass alert-dismissible d-flex align-items-start gap-2 mt-2" role="alert">
            <i class="bi @icon fs-5 flex-shrink-0 mt-1"></i>
            <div class="flex-grow-1 min-w-0">
                <strong>Document Expiry:</strong>
                @doc.DocumentType for <strong>@doc.VehicleRegistration</strong> @label —
                <a href="#" class="alert-link" @onclick='() => { activeTab = "documents"; }' @onclick:preventDefault>View Documents</a>
            </div>
            <button type="button" class="btn-close flex-shrink-0" @onclick="() => expiringDocs.Remove(doc)"></button>
        </div>
    }

    @foreach (var fault in openFaults)
    {
        <div class="alert alert-danger alert-dismissible d-flex align-items-start gap-2 mt-2" role="alert">
            <i class="bi bi-exclamation-triangle-fill fs-5 flex-shrink-0 mt-1"></i>
            <div class="flex-grow-1 min-w-0">
                <strong>Fault Reported:</strong>
                @fault.FaultType on <strong>@fault.VehicleRegistration</strong>
                by @fault.DriverEmail —
                <a href="#" class="alert-link" @onclick="() => OpenFaultDetail(fault)" @onclick:preventDefault>View Report</a>
            </div>
            <button type="button" class="btn-close flex-shrink-0" @onclick="() => DismissFaultAlert(fault)"></button>
        </div>
    }

    <div class="page-header mt-2 mb-3">
        <h3 class="mb-0">Fleet Overview</h3>
        <div class="header-actions">
            <div class="position-relative">
                <button class="btn btn-outline-secondary position-relative" @onclick="ToggleNotifications">
                    <i class="bi bi-bell fs-5"></i>
                    @if (allFaults.Count(f => f.Status == "Open") + mileageAlerts.Count > 0)
                    {
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                            @(allFaults.Count(f => f.Status == "Open") + mileageAlerts.Count)
                        </span>
                    }
                </button>
                @if (showNotifications)
                {
                    <div class="notifications-panel card shadow">
                        <div class="card-header d-flex justify-content-between align-items-center py-2">
                            <strong><i class="bi bi-bell me-2"></i>Notifications</strong>
                            <button class="btn btn-sm btn-link text-muted p-0" @onclick="ToggleNotifications">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                        <div class="card-body p-0" style="max-height: 400px; overflow-y: auto;">
                            @if (mileageAlerts.Any())
                            {
                                <div class="px-3 pt-2 pb-1">
                                    <small class="text-uppercase fw-bold text-warning" style="font-size:0.7rem;">⚠️ Mileage Not Updated</small>
                                </div>
                                @foreach (var alert in mileageAlerts)
                                {
                                    <div class="notification-item p-3 border-bottom bg-warning-subtle">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <span class="badge bg-warning text-dark me-1">Mileage</span>
                                                <strong>@alert.DriverName</strong>
                                            </div>
                                            <small class="text-muted ms-2 flex-shrink-0">@alert.VehicleReg</small>
                                        </div>
                                        <div class="mt-1 small text-muted">
                                            <i class="bi bi-speedometer2 me-1"></i>Last: @alert.Mileage km
                                            &nbsp;·&nbsp;<i class="bi bi-person me-1"></i>@alert.DriverEmail
                                        </div>
                                        <div class="mt-1 small text-warning-emphasis">Has not logged a trip in the last 12 hours</div>
                                    </div>
                                }
                                <div class="px-3 pt-2 pb-1 border-top">
                                    <small class="text-uppercase fw-bold text-muted" style="font-size:0.7rem;">Fault Reports</small>
                                </div>
                            }
                            @if (!allFaults.Any())
                            {
                                <div class="text-center text-muted py-4">
                                    <i class="bi bi-check-circle fs-3"></i>
                                    <p class="mt-2 mb-0">No fault reports</p>
                                </div>
                            }
                            else
                            {
                                @foreach (var fault in allFaults.OrderByDescending(f => f.CreatedAt))
                                {
                                    <div class="notification-item p-3 border-bottom @(fault.Status == "Open" ? "bg-danger-subtle" : "")"
                                         style="cursor:pointer" @onclick="() => OpenFaultDetail(fault)">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <span class="badge @(fault.Status == "Open" ? "bg-danger" : "bg-success") me-1">@fault.Status</span>
                                                <strong>@fault.FaultType</strong>
                                            </div>
                                            <small class="text-muted ms-2 flex-shrink-0">@fault.CreatedAt.ToLocalTime().ToString("dd MMM HH:mm")</small>
                                        </div>
                                        <div class="mt-1 small text-muted">
                                            <i class="bi bi-car-front me-1"></i>@fault.VehicleRegistration
                                            &nbsp;·&nbsp;<i class="bi bi-person me-1"></i>@fault.DriverEmail
                                        </div>
                                        <div class="mt-1 small text-truncate">@fault.Description</div>
                                    </div>
                                }
                            }
                        </div>
                        @if (allFaults.Any(f => f.Status == "Open"))
                        {
                            <div class="card-footer text-center py-2">
                                <button class="btn btn-sm btn-outline-primary" @onclick='() => { activeTab = "faults"; showNotifications = false; }'>
                                    View All in Faults Tab
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
            <button class="btn btn-outline-secondary" @onclick='() => NavigationManager.NavigateTo("/settings")'>
                <i class="bi bi-gear me-1"></i><span class="d-none d-sm-inline"> Settings</span>
            </button>
            <button class="btn btn-primary" @onclick="() => { isVehicleModalVisible = true; modalError = string.Empty; }">
                <i class="bi bi-plus-circle me-1"></i><span class="d-none d-sm-inline"> Add Vehicle</span>
            </button>
            <button class="btn btn-secondary" @onclick="async () => { await LoadFuelCards(); isDriverModalVisible = true; modalError = string.Empty; }">
                <i class="bi bi-person-plus me-1"></i><span class="d-none d-sm-inline"> Add Driver</span>
            </button>
            <button class="btn btn-warning" @onclick="OpenFuelCardModal">
                <i class="bi bi-credit-card me-1"></i><span class="d-none d-sm-inline"> Fuel Cards</span>
            </button>

        </div>
    </div>

    <ul class="nav nav-tabs mb-3 flex-nowrap overflow-auto">
        <li class="nav-item flex-shrink-0">
            <button class="nav-link @(activeTab == "vehicles" ? "active" : "")" @onclick='() => activeTab = "vehicles"'>
                <i class="bi bi-truck me-1"></i> Vehicles <span class="badge bg-secondary ms-1">@vehicles.Count</span>
            </button>
        </li>
        <li class="nav-item flex-shrink-0">
            <button class="nav-link @(activeTab == "drivers" ? "active" : "")" @onclick='() => activeTab = "drivers"'>
                <i class="bi bi-people me-1"></i> Drivers <span class="badge bg-secondary ms-1">@drivers.Count</span>
            </button>
        </li>
        <li class="nav-item flex-shrink-0">
            <button class="nav-link @(activeTab == "faults" ? "active" : "") position-relative" @onclick='() => activeTab = "faults"'>
                <i class="bi bi-exclamation-triangle me-1"></i> Faults
                @if (allFaults.Count(f => f.Status == "Open") > 0)
                {
                    <span class="badge bg-danger ms-1">@allFaults.Count(f => f.Status == "Open")</span>
                }
            </button>
        </li>
        <li class="nav-item flex-shrink-0">
            <button class="nav-link @(activeTab == "fuellogs" ? "active" : "")" @onclick='() => activeTab = "fuellogs"'>
                <i class="bi bi-fuel-pump me-1"></i> Fuel Logs <span class="badge bg-secondary ms-1">@allFuelLogs.Count</span>
            </button>
        </li>
        <li class="nav-item flex-shrink-0">
            <button class="nav-link @(activeTab == "documents" ? "active" : "") position-relative" @onclick='() => activeTab = "documents"'>
                <i class="bi bi-folder2-open me-1"></i> Documents
                @if (expiringDocs.Any())
                {
                    <span class="badge bg-danger ms-1">@expiringDocs.Count</span>
                }
            </button>
        </li>
        <li class="nav-item flex-shrink-0">
            <button class="nav-link @(activeTab == "reports" ? "active" : "")" @onclick='() => activeTab = "reports"'>
                <i class="bi bi-download me-1"></i> Reports
            </button>
        </li>
    </ul>

    @if (activeTab == "vehicles")
    {
        <div class="card shadow-sm d-none d-md-block">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Vehicle</th><th>Registration</th><th>Status</th>
                            <th>Mileage</th><th>Service Due</th><th>Driver</th><th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (vehicles.Any())
                        {
                            @foreach (var car in vehicles)
                            {
                                <tr>
                                    <td>
                                        <button class="btn btn-link p-0 text-dark fw-semibold text-decoration-none history-link"
                                                @onclick="() => OpenVehicleHistory(car)">
                                            @car.Make @car.Model
                                        </button>
                                    </td>
                                    <td><strong>@car.Registration</strong></td>
                                    <td><span class="badge @GetStatusBadge(car.Status)">@car.Status</span></td>
                                    <td>@car.Mileage km</td>
                                    <td>
                                        @if (car.Mileage >= car.ServiceDueKm)
                                        { <span class="text-danger fw-bold">@car.ServiceDueKm km ⚠️</span> }
                                        else
                                        { <span>@car.ServiceDueKm km</span> }
                                    </td>
                                    <td>@(car.LastDriver ?? "Unassigned")</td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => SelectVehicle(car)"><i class="bi bi-pencil"></i></button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDeleteVehicle(car)"><i class="bi bi-trash"></i></button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else { <tr><td colspan="7" class="text-center text-muted py-4">No vehicles found.</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="d-md-none">
            @foreach (var car in vehicles)
            {
                <div class="card shadow-sm mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <button class="btn btn-link p-0 text-dark fw-bold text-decoration-none history-link"
                                        @onclick="() => OpenVehicleHistory(car)">
                                    @car.Make @car.Model
                                </button>
                                <span class="text-muted small d-block">@car.Registration</span>
                            </div>
                            <span class="badge @GetStatusBadge(car.Status)">@car.Status</span>
                        </div>
                        <div class="row g-2 small text-muted mb-3">
                            <div class="col-6"><i class="bi bi-speedometer2 me-1"></i> @car.Mileage km</div>
                            <div class="col-6">
                                <i class="bi bi-tools me-1"></i>
                                @if (car.Mileage >= car.ServiceDueKm)
                                { <span class="text-danger fw-bold">@car.ServiceDueKm km ⚠️</span> }
                                else { <span>@car.ServiceDueKm km</span> }
                            </div>
                            <div class="col-12"><i class="bi bi-person me-1"></i> @(car.LastDriver ?? "Unassigned")</div>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-outline-primary flex-grow-1" @onclick="() => SelectVehicle(car)"><i class="bi bi-pencil me-1"></i> Edit</button>
                            <button class="btn btn-sm btn-outline-danger flex-grow-1" @onclick="() => ConfirmDeleteVehicle(car)"><i class="bi bi-trash me-1"></i> Remove</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (activeTab == "drivers")
    {
        <div class="card shadow-sm d-none d-md-block">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th><th>Email</th><th>Phone</th><th>Role</th><th>Rating</th><th>Status</th><th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (drivers.Any())
                        {
                            @foreach (var driver in drivers)
                            {
                                <tr class="@(!driver.IsActive ? "table-secondary text-muted" : "")">
                                    <td>
                                        <i class="bi bi-person-circle me-2 text-secondary"></i>
                                        <button class="btn btn-link p-0 text-dark fw-semibold text-decoration-none history-link"
                                                @onclick="() => OpenDriverProfile(driver)">
                                            @driver.Name
                                        </button>
                                    </td>
                                    <td>@driver.Email</td>
                                    <td>@(string.IsNullOrEmpty(driver.Phone) ? "—" : driver.Phone)</td>
                                    <td>
                                        <span class="badge @(driver.Role == "Admin" ? "bg-warning text-dark" : "bg-info text-dark")">@driver.Role</span>
                                    </td>
                                    <td>@RenderStars(GetDriverRating(driver.Email))</td>
                                    <td>
                                        <span class="badge @(driver.IsActive ? "bg-success" : "bg-secondary")">
                                            @(driver.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => SelectDriver(driver)"><i class="bi bi-pencil"></i></button>
                                            @if (driver.IsActive)
                                            {
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDeactivateDriver(driver)"><i class="bi bi-person-x"></i></button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-outline-success" @onclick="() => ReactivateDriver(driver)"><i class="bi bi-person-check"></i></button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else { <tr><td colspan="7" class="text-center text-muted py-4">No drivers found.</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="d-md-none">
            @foreach (var driver in drivers)
            {
                <div class="card shadow-sm mb-3 @(!driver.IsActive ? "opacity-75" : "")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <button class="btn btn-link p-0 text-dark fw-bold text-decoration-none history-link"
                                        @onclick="() => OpenDriverProfile(driver)">
                                    @driver.Name
                                </button>
                                <span class="text-muted small d-block">@driver.Email</span>
                            </div>
                            <div class="d-flex gap-1 flex-wrap justify-content-end">
                                <span class="badge @(driver.Role == "Admin" ? "bg-warning text-dark" : "bg-info text-dark")">@driver.Role</span>
                                <span class="badge @(driver.IsActive ? "bg-success" : "bg-secondary")">@(driver.IsActive ? "Active" : "Inactive")</span>
                            </div>
                        </div>
                        <div class="mb-2">@RenderStars(GetDriverRating(driver.Email))</div>
                        @if (!string.IsNullOrEmpty(driver.Phone))
                        {
                            <div class="small text-muted mb-3"><i class="bi bi-phone me-1"></i> @driver.Phone</div>
                        }
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-outline-primary flex-grow-1" @onclick="() => SelectDriver(driver)"><i class="bi bi-pencil me-1"></i> Edit</button>
                            @if (driver.IsActive)
                            {
                                <button class="btn btn-sm btn-outline-danger flex-grow-1" @onclick="() => ConfirmDeactivateDriver(driver)"><i class="bi bi-person-x me-1"></i> Deactivate</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-success flex-grow-1" @onclick="() => ReactivateDriver(driver)"><i class="bi bi-person-check me-1"></i> Reactivate</button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (activeTab == "faults")
    {
        <div class="card shadow-sm d-none d-md-block">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Date</th><th>Vehicle</th><th>Driver</th><th>Type</th>
                            <th>Description</th><th>Status</th><th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (allFaults.Any())
                        {
                            @foreach (var fault in allFaults.OrderByDescending(f => f.CreatedAt))
                            {
                                <tr>
                                    <td>@fault.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                                    <td><strong>@fault.VehicleRegistration</strong></td>
                                    <td>@fault.DriverEmail</td>
                                    <td><span class="badge bg-warning text-dark">@fault.FaultType</span></td>
                                    <td class="text-truncate" style="max-width:200px">@fault.Description</td>
                                    <td><span class="badge @(fault.Status == "Open" ? "bg-danger" : "bg-success")">@fault.Status</span></td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenFaultDetail(fault)"><i class="bi bi-eye"></i></button>
                                            @if (fault.Status == "Open")
                                            {
                                                <button class="btn btn-sm btn-outline-success" @onclick="() => ResolveFault(fault)"><i class="bi bi-check-lg"></i></button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else { <tr><td colspan="7" class="text-center text-muted py-4">No fault reports found.</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="d-md-none">
            @foreach (var fault in allFaults.OrderByDescending(f => f.CreatedAt))
            {
                <div class="card shadow-sm mb-3 @(fault.Status == "Open" ? "border-danger" : "")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <span class="badge bg-warning text-dark me-1">@fault.FaultType</span>
                                <span class="badge @(fault.Status == "Open" ? "bg-danger" : "bg-success")">@fault.Status</span>
                            </div>
                            <small class="text-muted">@fault.CreatedAt.ToLocalTime().ToString("dd MMM HH:mm")</small>
                        </div>
                        <div class="small text-muted mb-1">
                            <i class="bi bi-car-front me-1"></i><strong>@fault.VehicleRegistration</strong>
                            &nbsp;·&nbsp;<i class="bi bi-person me-1"></i>@fault.DriverEmail
                        </div>
                        <p class="small mb-3 text-truncate">@fault.Description</p>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-outline-primary flex-grow-1" @onclick="() => OpenFaultDetail(fault)"><i class="bi bi-eye me-1"></i> View</button>
                            @if (fault.Status == "Open")
                            {
                                <button class="btn btn-sm btn-outline-success flex-grow-1" @onclick="() => ResolveFault(fault)"><i class="bi bi-check-lg me-1"></i> Resolve</button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>


    @if (activeTab == "fuellogs")
    {
        <div class="card shadow-sm d-none d-md-block">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Date</th><th>Vehicle</th><th>Driver</th><th>Type</th>
                            <th>Litres</th><th>Cost (R)</th><th>Mileage</th><th>Card #</th><th>Receipt</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (allFuelLogs.Any())
                        {
                            @foreach (var log in allFuelLogs.OrderByDescending(l => l.LoggedAt))
                            {
                                <tr>
                                    <td>@log.LoggedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                                    <td><strong>@log.VehicleRegistration</strong></td>
                                    <td>@log.DriverEmail</td>
                                    <td>
                                        @if (log.ExpenseType == "Fuel")
                                        { <span class="badge bg-warning text-dark">@log.FuelType</span> }
                                        else
                                        { <span class="badge bg-secondary">@log.ExpenseCategory</span> }
                                    </td>
                                    <td>@(log.Litres.HasValue ? $"{log.Litres:F1} L" : "—")</td>
                                    <td>R @log.Cost.ToString("F2")</td>
                                    <td>@(log.MileageKm.HasValue ? $"{log.MileageKm} km" : "—")</td>
                                    <td>@(string.IsNullOrEmpty(log.FuelCardNumber) ? "—" : log.FuelCardNumber)</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(log.ReceiptUrl))
                                        { <a href="@log.ReceiptUrl" target="_blank" class="btn btn-sm btn-outline-primary"><i class="bi bi-image"></i></a> }
                                        else
                                        { <span class="text-muted small">—</span> }
                                    </td>
                                </tr>
                            }
                        }
                        else { <tr><td colspan="9" class="text-center text-muted py-4">No fuel logs yet.</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="d-md-none">
            @if (!allFuelLogs.Any())
            {
                <p class="text-center text-muted py-4">No fuel logs yet.</p>
            }
            @foreach (var log in allFuelLogs.OrderByDescending(l => l.LoggedAt))
            {
                <div class="card shadow-sm mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <strong>@log.VehicleRegistration</strong>
                                <span class="text-muted small d-block">@log.DriverEmail</span>
                            </div>
                            <div class="text-end">
                                @if (log.ExpenseType == "Fuel")
                                { <span class="badge bg-warning text-dark">@log.FuelType</span> }
                                else
                                { <span class="badge bg-secondary">@log.ExpenseCategory</span> }
                                <div class="small text-muted mt-1">@log.LoggedAt.ToLocalTime().ToString("dd MMM HH:mm")</div>
                            </div>
                        </div>
                        <div class="row g-1 small text-muted mb-2">
                            @if (log.Litres.HasValue)
                            { <div class="col-6"><i class="bi bi-droplet me-1"></i>@($"{log.Litres:F1} L")</div> }
                            <div class="col-6"><i class="bi bi-cash me-1"></i>R @log.Cost.ToString("F2")</div>
                            @if (log.MileageKm.HasValue)
                            { <div class="col-6"><i class="bi bi-speedometer2 me-1"></i>@log.MileageKm km</div> }
                            @if (!string.IsNullOrEmpty(log.FuelCardNumber))
                            { <div class="col-12"><i class="bi bi-credit-card me-1"></i>@log.FuelCardNumber</div> }
                        </div>
                        @if (!string.IsNullOrEmpty(log.ReceiptUrl))
                        {
                            <a href="@log.ReceiptUrl" target="_blank" class="btn btn-sm btn-outline-primary w-100">
                                <i class="bi bi-image me-1"></i> View Receipt
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    }


@if (showNotifications)
{
    <div class="position-fixed top-0 start-0 w-100 h-100" style="z-index: 999;" @onclick="ToggleNotifications"></div>
}

<!-- FAULT DETAIL MODAL -->
@if (selectedFault != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1055;">
        <div class="modal-dialog modal-dialog-centered modal-fullscreen-sm-down">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2 text-danger"></i> Fault Report</h5>
                    <button type="button" class="btn-close" @onclick="() => selectedFault = null"></button>
                </div>
                <div class="modal-body">
                    <div class="list-group list-group-flush">
                        <div class="list-group-item d-flex justify-content-between flex-wrap gap-1">
                            <span class="text-muted"><i class="bi bi-car-front me-2"></i>Vehicle</span>
                            <span class="fw-semibold">@selectedFault.VehicleRegistration</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between flex-wrap gap-1">
                            <span class="text-muted"><i class="bi bi-person me-2"></i>Reported By</span>
                            <span class="fw-semibold text-break">@selectedFault.DriverEmail</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between flex-wrap gap-1">
                            <span class="text-muted"><i class="bi bi-tag me-2"></i>Fault Type</span>
                            <span class="badge bg-warning text-dark">@selectedFault.FaultType</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between flex-wrap gap-1">
                            <span class="text-muted"><i class="bi bi-calendar me-2"></i>Date</span>
                            <span class="fw-semibold">@selectedFault.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between flex-wrap gap-1">
                            <span class="text-muted"><i class="bi bi-flag me-2"></i>Status</span>
                            <span class="badge @(selectedFault.Status == "Open" ? "bg-danger" : "bg-success")">@selectedFault.Status</span>
                        </div>
                        <div class="list-group-item">
                            <span class="text-muted d-block mb-1"><i class="bi bi-chat-text me-2"></i>Description</span>
                            <p class="mb-0">@selectedFault.Description</p>
                        </div>
                    </div>
                </div>
                <div class="modal-footer flex-column gap-2">
                    @if (selectedFault.Status == "Open")
                    {
                        <button class="btn btn-success w-100" @onclick="() => ResolveFault(selectedFault)">
                            <i class="bi bi-check-lg me-1"></i> Mark as Resolved
                        </button>
                    }
                    <button class="btn btn-secondary w-100" @onclick="() => selectedFault = null">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- CONFIRM MODAL -->
@if (showConfirmModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1060;">
        <div class="modal-dialog modal-dialog-centered modal-fullscreen-sm-down">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-danger"><i class="bi bi-exclamation-triangle me-2"></i>@confirmTitle</h5>
                    <button type="button" class="btn-close" @onclick="() => showConfirmModal = false"></button>
                </div>
                <div class="modal-body"><p>@confirmMessage</p></div>
                <div class="modal-footer flex-column gap-2">
                    <button class="btn btn-danger w-100" @onclick="ExecuteConfirmAction"><i class="bi bi-check-lg me-1"></i> Confirm</button>
                    <button class="btn btn-secondary w-100" @onclick="() => showConfirmModal = false">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- ADD/EDIT VEHICLE MODAL -->
@if (isVehicleModalVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered modal-fullscreen-sm-down">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-plus-circle me-2"></i>@(selectedVehicle != null ? "Edit Vehicle" : "Add Vehicle")
                    </h5>
                    <button type="button" class="btn-close" @onclick="() => { isVehicleModalVisible = false; selectedVehicle = null; }"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(modalError))
                    {
                        <div class="alert alert-danger py-2">@modalError</div>
                    }
                    <EditForm Model="@newVehicle" OnValidSubmit="HandleSaveVehicle">
                        <div class="mb-3">
                            <label class="form-label">Make</label>
                            <InputText @bind-Value="newVehicle.Make" class="form-control" placeholder="e.g. Toyota" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Model</label>
                            <InputText @bind-Value="newVehicle.Model" class="form-control" placeholder="e.g. Hilux" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Registration</label>
                            <InputText @bind-Value="newVehicle.Registration" class="form-control" placeholder="e.g. GP 123-456" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Current Mileage (km)</label>
                            <InputNumber @bind-Value="newVehicle.Mileage" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Service Due At (km)</label>
                            <InputNumber @bind-Value="newVehicle.ServiceDueKm" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Status</label>
                            <InputSelect @bind-Value="newVehicle.Status" class="form-select">
                                <option value="Available">Available</option>
                                <option value="Active">Active</option>
                                <option value="In Service">In Service</option>
                                <option value="Inactive">Inactive</option>
                            </InputSelect>
                        </div>
                        <div class="d-flex flex-column gap-2 mt-3">
                            <button type="submit" class="btn btn-primary w-100"><i class="bi bi-save me-1"></i> Save Vehicle</button>
                            <button type="button" class="btn btn-secondary w-100"
                                    @onclick="() => { isVehicleModalVisible = false; selectedVehicle = null; }">Cancel</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<!-- ADD/EDIT DRIVER MODAL -->
@if (isDriverModalVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered modal-fullscreen-sm-down">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-person-plus me-2"></i>@(selectedDriver != null ? "Edit Driver" : "Register New Driver")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseDriverModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(modalError))
                    {
                        <div class="alert alert-danger py-2">@modalError</div>
                    }
                    <EditForm Model="@driverForm" OnValidSubmit="HandleSaveDriver">
                        <div class="mb-3">
                            <label class="form-label">Full Name</label>
                            <InputText @bind-Value="driverForm.Name" class="form-control" placeholder="e.g. John Smith" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <InputText @bind-Value="driverForm.Email" class="form-control"
                                       placeholder="e.g. john@company.com" disabled="@(selectedDriver != null)" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Phone</label>
                            <InputText @bind-Value="driverForm.Phone" class="form-control" placeholder="e.g. 071 234 5678" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Role</label>
                            <InputSelect @bind-Value="driverForm.Role" class="form-select">
                                <option value="Driver">Driver</option>
                                <option value="Manager">Manager</option>
                                <option value="Admin">Admin</option>
                            </InputSelect>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Fuel Card <span class="text-muted fw-normal small">(optional)</span></label>
                            <InputSelect @bind-Value="driverForm.FuelCardNumber" class="form-select">
                                <option value="">-- No card assigned --</option>
                                @foreach (var card in fuelCards.Where(c => c.IsActive))
                                {
                                    <option value="@card.CardNumber">@card.CardNumber @(string.IsNullOrEmpty(card.Provider) ? "" : $"({card.Provider})")</option>
                                }
                            </InputSelect>
                        </div>
                        @if (selectedDriver == null)
                        {
                            <div class="mb-3">
                                <label class="form-label">Temporary Password</label>
                                <InputText @bind-Value="tempPassword" class="form-control" type="password" placeholder="Min 6 characters" />
                            </div>
                        }
                        <div class="d-flex flex-column gap-2 mt-3">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-person-check me-1"></i>@(selectedDriver != null ? "Save Changes" : "Create Account")
                            </button>
                            <button type="button" class="btn btn-secondary w-100" @onclick="CloseDriverModal">Cancel</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<!-- ══════════════════════════════════════════════════ -->
<!-- VEHICLE HISTORY MODAL                              -->
<!-- ══════════════════════════════════════════════════ -->
@if (showVehicleHistory && vehicleHistoryTarget != null)
{
    <div class="modal-backdrop-custom" @onclick="CloseVehicleHistory">
        <div class="modal-card card shadow" @onclick:stopPropagation="true">
            <div class="p-4 border-bottom">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h5 class="mb-0 fw-bold"><i class="bi bi-clock-history me-2 text-primary"></i>Vehicle History</h5>
                        <span class="text-muted small">@vehicleHistoryTarget.Make @vehicleHistoryTarget.Model — @vehicleHistoryTarget.Registration</span>
                    </div>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CloseVehicleHistory"><i class="bi bi-x-lg"></i></button>
                </div>
            </div>

            <div class="p-4" style="overflow-y:auto; max-height: calc(85vh - 80px);">

                <!-- Stats -->
                <div class="row g-3 mb-4">
                    <div class="col-3">
                        <div class="text-center p-3 rounded-3 bg-primary bg-opacity-10">
                            <div class="fs-4 fw-bold text-primary">@vehicleServiceHistory.Count</div>
                            <div class="small text-muted">Services</div>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="text-center p-3 rounded-3 bg-danger bg-opacity-10">
                            <div class="fs-4 fw-bold text-danger">@vehicleFaultHistory.Count</div>
                            <div class="small text-muted">Faults</div>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="text-center p-3 rounded-3 bg-success bg-opacity-10">
                            <div class="fs-4 fw-bold text-success">@vehicleTripHistory.Count</div>
                            <div class="small text-muted">Trips</div>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="text-center p-3 rounded-3 bg-warning bg-opacity-10">
                            <div class="fs-4 fw-bold text-warning">@allFuelLogs.Count(f => f.VehicleId == vehicleHistoryTarget!.Id)</div>
                            <div class="small text-muted">Fuel Logs</div>
                        </div>
                    </div>
                </div>

                <!-- Service History -->
                <h6 class="fw-bold mb-3"><i class="bi bi-tools me-2 text-primary"></i>Service History</h6>
                @if (vehicleServiceHistory.Any())
                {
                    @foreach (var svc in vehicleServiceHistory.OrderByDescending(s => s.ServicedAt))
                    {
                        <div class="card border-0 bg-light mb-2">
                            <div class="card-body py-2 px-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="fw-semibold small">@(svc.ServiceStation ?? "Unknown station")</div>
                                        <div class="text-muted x-small">By @svc.DriverEmail</div>
                                    </div>
                                    <div class="text-end">
                                        <div class="small fw-semibold">@svc.MileageAtService km</div>
                                        <div class="text-muted x-small">@svc.ServicedAt.ToLocalTime().ToString("dd MMM yyyy")</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small mb-4">No service records yet.</p>
                }

                <!-- Trip / Driver History -->
                <h6 class="fw-bold mb-3 mt-4"><i class="bi bi-people me-2 text-success"></i>Driver Usage History</h6>
                @if (vehicleTripHistory.Any())
                {
                    @foreach (var trip in vehicleTripHistory.OrderByDescending(t => t.CreatedAt))
                    {
                        <div class="card border-0 bg-light mb-2">
                            <div class="card-body py-2 px-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="fw-semibold small">@trip.DriverName</div>
                                        <div class="text-muted x-small">@trip.DriverEmail</div>
                                        @if (!string.IsNullOrEmpty(trip.ReturnCondition))
                                        {
                                            <span class="badge @GetConditionBadge(trip.ReturnCondition) mt-1">
                                                Returned: @trip.ReturnCondition
                                            </span>
                                        }
                                    </div>
                                    <div class="text-end">
                                        <div class="small fw-semibold">+@(trip.EndMileage - trip.StartMileage) km</div>
                                        <div class="text-muted x-small">@trip.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small mb-4">No trip records yet.</p>
                }


                <!-- Fuel Log History -->
                <h6 class="fw-bold mb-3 mt-4"><i class="bi bi-fuel-pump me-2 text-warning"></i>Fuel Log History</h6>
                @{
                    var vehicleFuelHistory = allFuelLogs
                        .Where(f => f.VehicleId == vehicleHistoryTarget.Id)
                        .OrderByDescending(f => f.LoggedAt).ToList();
                }
                @if (vehicleFuelHistory.Any())
                {
                    @foreach (var log in vehicleFuelHistory)
                    {
                        <div class="card border-0 bg-light mb-2">
                            <div class="card-body py-2 px-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        @if (log.ExpenseType == "Fuel")
                                        {
                                            <span class="badge bg-warning text-dark me-1">@log.FuelType</span>
                                            <span class="small fw-semibold">@($"{log.Litres:F1} L") · R @log.Cost.ToString("F2")</span>
                                            @if (log.MileageKm.HasValue)
                                            { <div class="text-muted x-small">Mileage: @log.MileageKm km</div> }
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary me-1">@log.ExpenseCategory</span>
                                            <span class="small fw-semibold">R @log.Cost.ToString("F2")</span>
                                        }
                                        <div class="text-muted x-small">@log.DriverEmail</div>
                                    </div>
                                    <div class="text-end">
                                        <div class="text-muted x-small">@log.LoggedAt.ToLocalTime().ToString("dd MMM yyyy")</div>
                                        @if (!string.IsNullOrEmpty(log.ReceiptUrl))
                                        {
                                            <a href="@log.ReceiptUrl" target="_blank" class="btn btn-sm btn-link p-0 small">Receipt</a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small">No fuel logs recorded.</p>
                }
                <!-- Fault History -->
                <h6 class="fw-bold mb-3 mt-4"><i class="bi bi-exclamation-triangle me-2 text-danger"></i>Fault History</h6>
                @if (vehicleFaultHistory.Any())
                {
                    @foreach (var fault in vehicleFaultHistory.OrderByDescending(f => f.CreatedAt))
                    {
                        <div class="card border-0 bg-light mb-2">
                            <div class="card-body py-2 px-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <span class="badge bg-warning text-dark me-1">@fault.FaultType</span>
                                        <span class="badge @(fault.Status == "Open" ? "bg-danger" : "bg-success")">@fault.Status</span>
                                        <div class="text-muted x-small mt-1">@fault.DriverEmail</div>
                                    </div>
                                    <div class="text-muted x-small">@fault.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</div>
                                </div>
                                <div class="small mt-1 text-truncate">@fault.Description</div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small">No faults recorded.</p>
                }
            </div>
        </div>
    </div>
}

<!-- ══════════════════════════════════════════════════ -->
<!-- DRIVER PROFILE MODAL                               -->
<!-- ══════════════════════════════════════════════════ -->
@if (showDriverProfile && driverProfileTarget != null)
{
    <div class="modal-backdrop-custom" @onclick="CloseDriverProfile">
        <div class="modal-card card shadow" @onclick:stopPropagation="true">
            <div class="p-4 border-bottom">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center gap-3">
                        <div class="driver-avatar">
                            <i class="bi bi-person-circle fs-1 text-secondary"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold">@driverProfileTarget.Name</h5>
                            <span class="badge @(driverProfileTarget.Role == "Admin" ? "bg-warning text-dark" : "bg-info text-dark")">
                                @driverProfileTarget.Role
                            </span>
                        </div>
                    </div>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CloseDriverProfile"><i class="bi bi-x-lg"></i></button>
                </div>
            </div>

            <div class="p-4" style="overflow-y:auto; max-height: calc(85vh - 80px);">

                <!-- Contact Info -->
                <h6 class="fw-bold mb-3"><i class="bi bi-person-lines-fill me-2 text-primary"></i>Contact Info</h6>
                <div class="card border-0 bg-light mb-4">
                    <div class="card-body py-2 px-3">
                        <div class="d-flex justify-content-between py-1 border-bottom">
                            <span class="text-muted small">Email</span>
                            <span class="small fw-semibold">@driverProfileTarget.Email</span>
                        </div>
                        <div class="d-flex justify-content-between py-1 border-bottom">
                            <span class="text-muted small">Phone</span>
                            <span class="small fw-semibold">@(string.IsNullOrEmpty(driverProfileTarget.Phone) ? "—" : driverProfileTarget.Phone)</span>
                        </div>
                        <div class="d-flex justify-content-between py-1">
                            <span class="text-muted small">Status</span>
                            <span class="badge @(driverProfileTarget.IsActive ? "bg-success" : "bg-secondary")">
                                @(driverProfileTarget.IsActive ? "Active" : "Inactive")
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Rating -->
                <h6 class="fw-bold mb-3"><i class="bi bi-star-fill me-2 text-warning"></i>Driver Rating</h6>
                <div class="card border-0 bg-light mb-4">
                    <div class="card-body py-3 px-3">
                        @{
                            var rating = GetDriverRating(driverProfileTarget.Email);
                            var driverFaultCount = allFaults.Count(f => f.DriverEmail == driverProfileTarget.Email);
                            var driverTrips = allTripHistory.Where(t => t.DriverEmail == driverProfileTarget.Email).ToList();
                            var cleanReturns = driverTrips.Count(t => t.ReturnCondition == "Clean" || t.ReturnCondition == "Good");
                        }
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="fs-4">@RenderStars(rating)</span>
                            <span class="fw-bold fs-5">@rating.ToString("0.0") / 5.0</span>
                        </div>
                        <div class="row g-2 mt-1">
                            <div class="col-6">
                                <div class="small text-muted">Faults reported</div>
                                <div class="fw-semibold @(driverFaultCount > 3 ? "text-danger" : "text-success")">
                                    @driverFaultCount fault@(driverFaultCount == 1 ? "" : "s")
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="small text-muted">Clean returns</div>
                                <div class="fw-semibold text-success">@cleanReturns / @driverTrips.Count</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Stats -->
                <div class="row g-3 mb-4">
                    <div class="col-4">
                        <div class="text-center p-3 rounded-3 bg-primary bg-opacity-10">
                            <div class="fs-4 fw-bold text-primary">@driverTrips.Count</div>
                            <div class="small text-muted">Trips</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="text-center p-3 rounded-3 bg-danger bg-opacity-10">
                            <div class="fs-4 fw-bold text-danger">@driverFaultCount</div>
                            <div class="small text-muted">Faults</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="text-center p-3 rounded-3 bg-success bg-opacity-10">
                            <div class="fs-4 fw-bold text-success">
                                @(driverTrips.Sum(t => t.EndMileage - t.StartMileage)) km
                            </div>
                            <div class="small text-muted">Total km</div>
                        </div>
                    </div>
                </div>

                <!-- Trip History -->
                <h6 class="fw-bold mb-3"><i class="bi bi-car-front me-2 text-success"></i>Vehicle Usage History</h6>
                @if (driverTrips.Any())
                {
                    @foreach (var trip in driverTrips.OrderByDescending(t => t.CreatedAt))
                    {
                        <div class="card border-0 bg-light mb-2">
                            <div class="card-body py-2 px-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="fw-semibold small">@trip.VehicleRegistration</div>
                                        @if (!string.IsNullOrEmpty(trip.ReturnCondition))
                                        {
                                            <span class="badge @GetConditionBadge(trip.ReturnCondition) mt-1">
                                                @trip.ReturnCondition
                                            </span>
                                        }
                                    </div>
                                    <div class="text-end">
                                        <div class="small fw-semibold">+@(trip.EndMileage - trip.StartMileage) km</div>
                                        <div class="text-muted x-small">@trip.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small mb-4">No trips recorded yet.</p>
                }

                <!-- Fault History -->
                <h6 class="fw-bold mb-3 mt-2"><i class="bi bi-exclamation-triangle me-2 text-danger"></i>Fault History</h6>
                @{
                    var driverFaults = allFaults.Where(f => f.DriverEmail == driverProfileTarget.Email)
                                                .OrderByDescending(f => f.CreatedAt).ToList();
                }
                @if (driverFaults.Any())
                {
                    @foreach (var fault in driverFaults)
                    {
                        <div class="card border-0 bg-light mb-2">
                            <div class="card-body py-2 px-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <span class="badge bg-warning text-dark me-1">@fault.FaultType</span>
                                        <span class="badge @(fault.Status == "Open" ? "bg-danger" : "bg-success")">@fault.Status</span>
                                        <div class="small mt-1 text-truncate" style="max-width:220px">@fault.Description</div>
                                    </div>
                                    <div class="text-muted x-small">@fault.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small">No faults reported.</p>
                }
            </div>
        </div>
    </div>
}

