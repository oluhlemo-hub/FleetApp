    private async Task HandleSaveVehicle()
    {
        modalError = ""; modalErrorDetail = "";
        try
        {
            if (string.IsNullOrWhiteSpace(newVehicle.Make) || string.IsNullOrWhiteSpace(newVehicle.Model) || string.IsNullOrWhiteSpace(newVehicle.Registration))
            {
                modalError = "Please fill in Make, Model and Registration.";
                return;
            }
            if (selectedVehicle != null)
            {
                await Supabase.From<Vehicle>().Where(v => v.Id == newVehicle.Id)
                    .Set(v => v.Make, newVehicle.Make)
                    .Set(v => v.Model, newVehicle.Model)
                    .Set(v => v.Registration, newVehicle.Registration)
                    .Set(v => v.Mileage, newVehicle.Mileage)
                    .Set(v => v.ServiceDueKm, newVehicle.ServiceDueKm)
                    .Set(v => v.Status, newVehicle.Status)
                    .Update();
                successMessage = $"{newVehicle.Registration} updated successfully.";
            }
            else
            {
                newVehicle.Id = Guid.NewGuid().ToString(); await Supabase.From<Vehicle>().Insert(newVehicle);
                successMessage = $"{newVehicle.Registration} added successfully.";
            }
            await LoadData();
            isVehicleModalVisible = false;
            selectedVehicle = null;
            newVehicle = new Vehicle { Status = "Available" };
        }
        catch (Exception ex) { modalError = "Error: " + ex.Message; }
    }

    private async Task HandleSaveDriver()
    {
        modalError = ""; modalErrorDetail = "";
        try
        {
            if (string.IsNullOrWhiteSpace(driverForm.Name) || string.IsNullOrWhiteSpace(driverForm.Email))
            {
                modalError = "Please fill in both Name and Email before continuing.";
                return;
            }

            if (selectedDriver != null)
            {
                // ── EDIT existing driver ──────────────────────────────────
                var updatedDriver = new Driver
                {
                    Id = selectedDriver.Id,
                    AuthId = selectedDriver.AuthId,
                    Name = driverForm.Name,
                    Email = selectedDriver.Email,
                    Phone = driverForm.Phone ?? "",
                    Role = driverForm.Role,
                    IsActive = selectedDriver.IsActive,
                    MustChangePassword = selectedDriver.MustChangePassword,
                    FuelCardNumber = string.IsNullOrWhiteSpace(driverForm.FuelCardNumber) ? null : driverForm.FuelCardNumber
                };
                await Supabase.From<Driver>().Update(updatedDriver);
                successMessage = $"✓ {driverForm.Name}'s details updated successfully.";
            }
            else
            {
                // ── CREATE new driver ─────────────────────────────────────
                if (string.IsNullOrWhiteSpace(tempPassword) || tempPassword.Length < 6)
                {
                    modalError = "Password must be at least 6 characters long.";
                    return;
                }

                // Step 1: create the auth account
                Supabase.Gotrue.Session? authResponse = null;
                try
                {
                    authResponse = await Supabase.Auth.SignUp(driverForm.Email, tempPassword);
                }
                catch (Supabase.Gotrue.Exceptions.GotrueException ex)
                {
                    modalError = ex.Message.Contains("user_already_exists")
                        ? $"An account for {driverForm.Email} already exists. Use a different email or reset their password."
                        : $"Could not create login account: {ex.Message}";
                    return;
                }

                if (authResponse?.User == null)
                {
                    modalError = "Account creation did not return a valid user. Please try again.";
                    return;
                }

                // Step 2: insert the driver profile (Id omitted — Postgres generates UUID)
                var driverRecord = new Driver
                {
                    Id = Guid.NewGuid().ToString(),
                    AuthId = authResponse.User.Id ?? "",
                    Name = driverForm.Name,
                    Email = driverForm.Email,
                    Phone = driverForm.Phone,
                    Role = driverForm.Role,
                    IsActive = true,
                    MustChangePassword = true,
                    TotalKmDriven = 0,
                    FuelCardNumber = string.IsNullOrWhiteSpace(driverForm.FuelCardNumber) ? null : driverForm.FuelCardNumber
                };

                try
                {
                    await Supabase.From<Driver>().Insert(driverRecord);
                }
                catch (Exception dbEx)
                {
                    modalError = $"Login account was created but the driver profile could not be saved ({dbEx.Message}). Please contact support.";
                    return;
                }

                successMessage = $"✓ Account created for {driverForm.Name}. They can now log in with their temporary password.";
            }

            await LoadData();
            CloseDriverModal();
        }
        catch (Exception ex)
        {
            modalError = $"An unexpected error occurred: {ex.Message}. Please try again or contact support.";
        }
    }

