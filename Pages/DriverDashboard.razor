@page "/driver"
@using FleetManagement.Models
@inject Supabase.Client Supabase
@inject NavigationManager Navigation

<AuthGuard RequiredRole="Driver">
<div class="container-fluid px-3 py-3">

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible">
            @successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = string.Empty"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible">
            @errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty"></button>
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-body text-center py-4">
            <div class="mb-2">
                <i class="bi bi-truck display-4 text-primary opacity-75"></i>
            </div>
            <h6 class="text-muted text-uppercase small fw-semibold mb-2">Assigned Vehicle</h6>
            @if (hasVehicle)
            {
                <h2 class="display-6 fw-bold mb-1">@currentVehicle.Registration</h2>
                <p class="text-muted mb-2">@currentVehicle.Make @currentVehicle.Model</p>
                <span class="badge bg-info fs-6 px-3 py-2">@currentVehicle.Status</span>
                @if (currentVehicle.Mileage >= currentVehicle.ServiceDueKm)
                {
                    <div class="alert alert-warning mt-3 py-2 mb-0">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        Service overdue at <strong>@currentVehicle.ServiceDueKm km</strong>
                    </div>
                }
            }
            else
            {
                <h4 class="text-muted">No vehicle assigned</h4>
                <p class="text-muted small">Request a vehicle below to get started.</p>
            }
        </div>
    </div>

    <div class="row g-3">
        <div class="col-6">
            @if (currentVehicle.Status == "In Service")
            {
                <button class="btn btn-success w-100 py-3 d-flex flex-column align-items-center gap-1"
                        @onclick="() => showCollectService = true"
                        disabled="@(!hasVehicle)">
                    <i class="bi bi-check-circle fs-4"></i>
                    <span class="small">Collect from Service</span>
                </button>
            }
            else
            {
                <button class="btn btn-primary w-100 py-3 d-flex flex-column align-items-center gap-1"
                        @onclick="() => showBookService = true"
                        disabled="@(!hasVehicle)">
                    <i class="bi bi-tools fs-4"></i>
                    <span class="small">Book Service</span>
                </button>
            }
        </div>
        <div class="col-6">
            <button class="btn btn-danger w-100 py-3 d-flex flex-column align-items-center gap-1"
                    @onclick="() => showReportFault = true"
                    disabled="@(!hasVehicle)">
                <i class="bi bi-exclamation-triangle fs-4"></i>
                <span class="small">Report Fault</span>
            </button>
        </div>
        <div class="col-12">
            @if (hasVehicle)
            {
                <button class="btn btn-dark w-100 py-3 d-flex align-items-center justify-content-center gap-2"
                        @onclick="() => showReturnVehicle = true">
                    <i class="bi bi-car-front fs-5"></i>
                    <span>Return Vehicle</span>
                </button>
            }
            else
            {
                <button class="btn btn-success w-100 py-3 d-flex align-items-center justify-content-center gap-2"
                        @onclick="OpenRequestVehicle">
                    <i class="bi bi-key fs-5"></i>
                    <span>Request Vehicle</span>
                </button>
            }
        </div>
    </div>

    <!-- Book Service Modal -->
    @if (showBookService)
    {
        <div class="modal-backdrop-custom">
            <div class="modal-card card shadow p-4">
                <h5 class="mb-3"><i class="bi bi-tools me-2"></i>Book Service</h5>
                <div class="mb-3">
                    <label class="form-label">Service Station</label>
                    <input class="form-control form-control-lg" @bind="serviceStation" placeholder="e.g. AutoZone Sandton" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Current Mileage (km)</label>
                    <input type="number" class="form-control form-control-lg" @bind="serviceMileage" placeholder="e.g. 45000" />
                </div>
                <div class="mb-4">
                    <label class="form-label">Vehicle</label>
                    <input class="form-control" value="@currentVehicle.Registration — @currentVehicle.Make @currentVehicle.Model" disabled />
                </div>
                <div class="d-flex flex-column gap-2">
                    <button class="btn btn-primary btn-lg w-100" @onclick="SubmitBookService" disabled="@isSubmitting">
                        @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-2"></span> } Submit
                    </button>
                    <button class="btn btn-outline-secondary w-100" @onclick="() => showBookService = false">Cancel</button>
                </div>
            </div>
        </div>
    }

    <!-- Collect from Service Modal -->
    @if (showCollectService)
    {
        <div class="modal-backdrop-custom">
            <div class="modal-card card shadow p-4">
                <h5 class="mb-3"><i class="bi bi-check-circle me-2 text-success"></i>Collect from Service</h5>

                <div class="mb-3">
                    <label class="form-label">Vehicle</label>
                    <input class="form-control" value="@currentVehicle.Registration — @currentVehicle.Make @currentVehicle.Model" disabled />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Updated Mileage after Service (km)</label>
                    <input type="number" class="form-control form-control-lg" @bind="collectMileage"
                           placeholder="e.g. 45200" />
                    <small class="text-muted">Next service will be set to this mileage + 10,000 km.</small>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Service Report</label>
                    <InputFile OnChange="OnServiceReportSelected" accept="image/*,application/pdf" class="form-control" />
                    @if (serviceReportName != null)
                    {
                        <div class="mt-2 d-flex align-items-center gap-2">
                            <i class="bi @(serviceReportName.EndsWith(".pdf") ? "bi-file-pdf text-danger" : "bi-image text-primary") fs-5"></i>
                            <small class="text-muted">@serviceReportName</small>
                        </div>
                    }
                    <small class="text-muted d-block mt-1">Upload the service report or take a photo of it. Accepts image or PDF.</small>
                </div>

                @if (!string.IsNullOrEmpty(collectError))
                {
                    <div class="alert alert-danger py-2 mb-3">@collectError</div>
                }

                <div class="d-flex flex-column gap-2">
                    <button class="btn btn-success btn-lg w-100" @onclick="SubmitCollectService" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Processing...</span>
                        }
                        else
                        {
                            <i class="bi bi-check-lg me-1"></i>
                            <span>Confirm Collection</span>
                        }
                    </button>
                    <button class="btn btn-outline-secondary w-100" @onclick="() => { showCollectService = false; collectError = string.Empty; }">Cancel</button>
                </div>
            </div>
        </div>
    }

    <!-- Report Fault Modal -->
    @if (showReportFault)
    {
        <div class="modal-backdrop-custom">
            <div class="modal-card card shadow p-4">
                <h5 class="mb-3"><i class="bi bi-exclamation-triangle me-2"></i>Report Fault</h5>
                <div class="mb-3">
                    <label class="form-label">Fault Type</label>
                    <select class="form-select form-select-lg" @bind="faultType">
                        <option value="">-- Select type --</option>
                        <option>Mechanical</option>
                        <option>Accident</option>
                        <option>Electrical</option>
                        <option>Tyre</option>
                        <option>Other</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" rows="4" @bind="faultDescription"
                              placeholder="Describe the fault in detail..."></textarea>
                </div>
                <div class="mb-4">
                    <label class="form-label">Photo (optional)</label>
                    <InputFile OnChange="OnFaultPhotoSelected" accept="image/*" class="form-control" />
                    @if (faultPhotoName != null)
                    {
                        <small class="text-muted mt-1 d-block"><i class="bi bi-image me-1"></i>@faultPhotoName</small>
                    }
                </div>
                <div class="d-flex flex-column gap-2">
                    <button class="btn btn-danger btn-lg w-100" @onclick="SubmitFaultReport" disabled="@isSubmitting">
                        @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-2"></span> } Submit Report
                    </button>
                    <button class="btn btn-outline-secondary w-100" @onclick="() => showReportFault = false">Cancel</button>
                </div>
            </div>
        </div>
    }

    <!-- Return Vehicle Modal -->
    @if (showReturnVehicle)
    {
        <div class="modal-backdrop-custom">
            <div class="modal-card card shadow p-4">
                <h5 class="mb-3"><i class="bi bi-car-front me-2"></i>Return Vehicle</h5>
                <div class="mb-3">
                    <label class="form-label">Vehicle</label>
                    <input class="form-control" value="@currentVehicle.Registration — @currentVehicle.Make @currentVehicle.Model" disabled />
                </div>
                <div class="mb-3">
                    <label class="form-label">Updated Mileage (km)</label>
                    <input type="number" class="form-control form-control-lg" @bind="returnMileage" placeholder="e.g. 46500" />
                </div>
                <div class="mb-4">
                    <label class="form-label">Vehicle Condition</label>
                    <select class="form-select form-select-lg" @bind="returnCondition">
                        <option value="">-- Select condition --</option>
                        <option>Clean</option>
                        <option>Dirty</option>
                        <option>Good</option>
                    </select>
                </div>
                <div class="d-flex flex-column gap-2">
                    <button class="btn btn-dark btn-lg w-100" @onclick="SubmitReturnVehicle" disabled="@isSubmitting">
                        @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-2"></span> } Confirm Return
                    </button>
                    <button class="btn btn-outline-secondary w-100" @onclick="() => showReturnVehicle = false">Cancel</button>
                </div>
            </div>
        </div>
    }

    <!-- Request Vehicle Modal -->
    @if (showRequestVehicle)
    {
        <div class="modal-backdrop-custom">
            <div class="modal-card card shadow p-4">
                <h5 class="mb-3"><i class="bi bi-key me-2"></i>Request Vehicle</h5>

                @if (!isOtpSent)
                {
                    <div class="mb-3">
                        <label class="form-label">Available Vehicles</label>
                        @if (availableVehicles.Any())
                        {
                            <select class="form-select form-select-lg" @bind="requestedVehicleId">
                                <option value="">-- Select vehicle --</option>
                                @foreach (var v in availableVehicles)
                                {
                                    <option value="@v.Id">@v.Registration — @v.Make @v.Model</option>
                                }
                            </select>
                        }
                        else
                        {
                            <div class="alert alert-warning py-2">
                                <i class="bi bi-info-circle me-1"></i> No vehicles currently available.
                            </div>
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Current Mileage (km)</label>
                        <input type="number" class="form-control form-control-lg" @bind="requestMileage" placeholder="e.g. 45000" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Admin Email Address</label>
                        <input type="email" class="form-control form-control-lg" @bind="requestApprover" placeholder="admin@yourcompany.com" />
                    </div>
                    <div class="d-flex flex-column gap-2">
                        <button class="btn btn-primary btn-lg w-100" @onclick="GenerateAndRequestOtp"
                                disabled="@(string.IsNullOrEmpty(requestedVehicleId) || requestMileage <= 0 || string.IsNullOrEmpty(requestApprover) || isSubmitting)">
                            @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-2"></span><span>Sending Email...</span> }
                            else { <span>Request Approval OTP</span> }
                        </button>
                        <button class="btn btn-outline-secondary w-100" @onclick="() => showRequestVehicle = false">Cancel</button>
                    </div>
                }
                else
                {
                    <div class="alert alert-info py-2 mb-3 text-center">
                        <i class="bi bi-envelope-check me-1"></i> An approval code was sent to <strong>@requestApprover</strong>.
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Enter 6-Digit Admin OTP</label>
                        <input type="text" maxlength="6" class="form-control form-control-lg text-center letter-spacing-lg fw-bold"
                               @bind="enteredOtp" placeholder="000000" />
                    </div>
                    <div class="d-flex flex-column gap-2">
                        <button class="btn btn-success btn-lg w-100" @onclick="SubmitVehicleRequest" disabled="@isSubmitting">
                            @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-2"></span> } Verify & Claim Vehicle
                        </button>
                        <button class="btn btn-link text-muted small w-100" @onclick="() => isOtpSent = false">Back to change email</button>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Update Mileage Modal -->
    @if (showUpdateMileage)
    {
        <div class="modal-backdrop-custom">
            <div class="modal-card card shadow p-4">
                <h5 class="mb-3"><i class="bi bi-speedometer2 me-2"></i>Update Mileage</h5>
                @if (!hasVehicle)
                {
                    <div class="alert alert-warning">No vehicle is currently assigned to you.</div>
                }
                else
                {
                    <div class="mb-3">
                        <label class="form-label">Vehicle</label>
                        <input class="form-control" value="@currentVehicle.Registration — @currentVehicle.Make @currentVehicle.Model" disabled />
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Current Mileage (km)</label>
                        <input type="number" class="form-control form-control-lg" @bind="updateMileageValue" placeholder="e.g. 47200" />
                    </div>
                    @if (mileageServiceWarning)
                    {
                        <div class="alert alert-warning py-2 mb-3">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            Service is due at <strong>@currentVehicle.ServiceDueKm km</strong>. Please book a service.
                        </div>
                    }
                }
                <div class="d-flex flex-column gap-2">
                    <button class="btn btn-primary btn-lg w-100" @onclick="SubmitUpdateMileage" disabled="@(!hasVehicle || isSubmitting)">
                        @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-2"></span> } Save Mileage
                    </button>
                    <button class="btn btn-outline-secondary w-100" @onclick="CloseUpdateMileage">Cancel</button>
                </div>
            </div>
        </div>
    }

</div>

<style>
    .modal-backdrop-custom {
        position: fixed;
        top: 0; left: 0;
        width: 100%; height: 100%;
        background: rgba(0,0,0,0.55);
        display: flex;
        align-items: flex-end;
        justify-content: center;
        z-index: 1050;
        padding: 0;
    }

    .modal-card {
        width: 100%;
        max-width: 520px;
        border-radius: 20px 20px 0 0;
        max-height: 92vh;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
        padding-bottom: calc(1.5rem + env(safe-area-inset-bottom, 0px)) !important;
    }

    .letter-spacing-lg {
        letter-spacing: 0.5rem;
        font-size: 1.5rem;
    }

    @@media (min-width: 576px) {
        .modal-backdrop-custom {
            align-items: center;
            padding: 1rem;
        }
        .modal-card {
            border-radius: 16px;
            max-height: 90vh;
        }
    }
</style>
</AuthGuard>

@code {
    private Vehicle currentVehicle = new();
    private List<Vehicle> availableVehicles = new();
    private bool hasVehicle = false;
    private string currentUserEmail = string.Empty;

    private string successMessage = string.Empty;
    private string errorMessage = string.Empty;
    private bool isSubmitting = false;

    // Book Service
    private bool showBookService = false;
    private string serviceStation = string.Empty;
    private int serviceMileage;

    // Collect from Service
    private bool showCollectService = false;
    private int collectMileage;
    private IBrowserFile? serviceReportFile;
    private string? serviceReportName;
    private string collectError = string.Empty;

    // Report Fault
    private bool showReportFault = false;
    private string faultType = string.Empty;
    private string faultDescription = string.Empty;
    private string? faultPhotoName;
    private IBrowserFile? faultPhoto;

    // Return Vehicle
    private bool showReturnVehicle = false;
    private int returnMileage;
    private string returnCondition = string.Empty;

    // Request Vehicle
    private bool showRequestVehicle = false;
    private string requestedVehicleId = string.Empty;
    private int requestMileage;
    private string requestApprover = string.Empty;
    private bool isOtpSent = false;
    private string generatedOtp = string.Empty;
    private string enteredOtp = string.Empty;

    // Update Mileage
    private bool showUpdateMileage = false;
    private int updateMileageValue;
    private bool mileageServiceWarning = false;

    protected override async Task OnInitializedAsync()
    {
        var session = Supabase.Auth.CurrentSession;
        if (session?.User?.Email != null)
        {
            currentUserEmail = session.User.Email;
            await LoadData();
            return;
        }

        for (int i = 0; i < 20; i++)
        {
            await Task.Delay(250);
            session = Supabase.Auth.CurrentSession;
            if (session?.User?.Email != null)
            {
                currentUserEmail = session.User.Email;
                await LoadData();
                return;
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var uri = new Uri(Navigation.Uri);
            var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
            if (query["action"] == "update-mileage")
            {
                showUpdateMileage = true;
                StateHasChanged();
            }
        }
    }

    private async Task LoadData()
    {
        if (!string.IsNullOrEmpty(currentUserEmail))
        {
            string driverName = currentUserEmail;
            try
            {
                var driverRecord = await Supabase.From<Driver>()
                    .Filter("email", Postgrest.Constants.Operator.Equals, currentUserEmail)
                    .Single();
                if (driverRecord != null)
                    driverName = driverRecord.Name;
            }
            catch { }

            var assigned = await Supabase.From<Vehicle>()
                .Filter("last_driver", Postgrest.Constants.Operator.Equals, driverName)
                .Get();

            if (assigned.Models.Any())
            {
                currentVehicle = assigned.Models.First();
                hasVehicle = true;
            }
            else
            {
                currentVehicle = new();
                hasVehicle = false;
            }
        }

        var available = await Supabase.From<Vehicle>()
            .Filter("status", Postgrest.Constants.Operator.Equals, "Available")
            .Get();
        availableVehicles = available.Models;
    }

    private async Task OpenRequestVehicle()
    {
        var available = await Supabase.From<Vehicle>()
            .Filter("status", Postgrest.Constants.Operator.Equals, "Available")
            .Get();
        availableVehicles = available.Models;
        isOtpSent = false;
        enteredOtp = string.Empty;
        showRequestVehicle = true;
    }

    private void OnFaultPhotoSelected(InputFileChangeEventArgs e)
    {
        faultPhoto = e.File;
        faultPhotoName = e.File.Name;
    }

    private void OnServiceReportSelected(InputFileChangeEventArgs e)
    {
        serviceReportFile = e.File;
        serviceReportName = e.File.Name;
    }

    private async Task SubmitBookService()
    {
        if (string.IsNullOrWhiteSpace(serviceStation) || serviceMileage <= 0)
        {
            errorMessage = "Please fill in all fields.";
            return;
        }
        isSubmitting = true;
        try
        {
            currentVehicle.Status = "In Service";
            currentVehicle.Mileage = serviceMileage;
            await Supabase.From<Vehicle>().Update(currentVehicle);
            await LoadData();
            showBookService = false;
            successMessage = $"Service booked at {serviceStation}. Button will change to 'Collect from Service' when ready.";
            serviceStation = string.Empty;
            serviceMileage = 0;
        }
        catch (Exception ex) { errorMessage = $"Failed to book service: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private async Task SubmitCollectService()
    {
        collectError = string.Empty;

        if (collectMileage <= 0)
        {
            collectError = "Please enter the updated mileage after service.";
            return;
        }
        if (serviceReportFile == null)
        {
            collectError = "Please upload the service report or a photo of it.";
            return;
        }

        isSubmitting = true;
        try
        {
            string reportUrl = string.Empty;
            try
            {
                var extension = Path.GetExtension(serviceReportFile.Name);
                var fileName = $"service-reports/{currentVehicle.Registration}_{DateTime.UtcNow:yyyyMMddHHmmss}{extension}";

                using var stream = serviceReportFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                var bytes = ms.ToArray();

                await Supabase.Storage
                    .From("vehicle-documents")
                    .Upload(bytes, fileName, new Supabase.Storage.FileOptions { Upsert = true });

                reportUrl = Supabase.Storage
                    .From("vehicle-documents")
                    .GetPublicUrl(fileName);
            }
            catch
            {
                collectError = "Warning: report upload failed, but mileage was updated.";
            }

            var serviceRecord = new ServiceHistory
            {
                VehicleId = currentVehicle.Id,
                VehicleRegistration = currentVehicle.Registration,
                DriverEmail = currentUserEmail,
                MileageAtService = collectMileage,
                NextServiceKm = collectMileage + 10000,
                ReportUrl = reportUrl,
                ServicedAt = DateTime.UtcNow
            };
            await Supabase.From<ServiceHistory>().Insert(serviceRecord);
            currentVehicle.Status = "Active";
            currentVehicle.Mileage = collectMileage;
            currentVehicle.ServiceDueKm = collectMileage + 10000;
            await Supabase.From<Vehicle>().Update(currentVehicle);

            await LoadData();
            showCollectService = false;
            collectMileage = 0;
            serviceReportFile = null;
            serviceReportName = null;

            successMessage = $"Vehicle collected from service. Mileage updated to {collectMileage} km. Next service due at {collectMileage + 10000} km.";
        }
        catch (Exception ex) { collectError = $"Failed to collect vehicle: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private async Task SubmitFaultReport()
    {
        if (string.IsNullOrWhiteSpace(faultType) || string.IsNullOrWhiteSpace(faultDescription))
        {
            errorMessage = "Please select a fault type and add a description.";
            return;
        }
        isSubmitting = true;
        try
        {
            var fault = new Fault
            {
                VehicleId = currentVehicle.Id,
                VehicleRegistration = currentVehicle.Registration,
                DriverEmail = currentUserEmail,
                FaultType = faultType,
                Description = faultDescription,
                Status = "Open",
                CreatedAt = DateTime.UtcNow
            };
            await Supabase.From<Fault>().Insert(fault);
            showReportFault = false;
            successMessage = "Fault report submitted successfully.";
            faultType = string.Empty;
            faultDescription = string.Empty;
            faultPhoto = null;
            faultPhotoName = null;
        }
        catch (Exception ex) { errorMessage = $"Failed to submit fault report: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private async Task SubmitReturnVehicle()
    {
        if (returnMileage <= 0 || string.IsNullOrWhiteSpace(returnCondition))
        {
            errorMessage = "Please enter mileage and condition.";
            return;
        }
        isSubmitting = true;
        try
        {
            // Record trip history before clearing the driver
            string driverName = currentUserEmail;
            try
            {
                var driverRecord = await Supabase.From<Driver>()
                    .Filter("email", Postgrest.Constants.Operator.Equals, currentUserEmail)
                    .Single();
                if (driverRecord != null)
                    driverName = driverRecord.Name;
            }
            catch { }

            var trip = new TripHistory
            {
                VehicleId = currentVehicle.Id,
                VehicleRegistration = currentVehicle.Registration,
                DriverEmail = currentUserEmail,
                DriverName = driverName,
                StartMileage = currentVehicle.Mileage,
                EndMileage = returnMileage,
                ReturnCondition = returnCondition,
                CreatedAt = DateTime.UtcNow
            };
            await Supabase.From<TripHistory>().Insert(trip);

            // Now update the vehicle
            currentVehicle.Status = "Available";
            currentVehicle.Mileage = returnMileage;
            currentVehicle.LastDriver = string.Empty;
            await Supabase.From<Vehicle>().Update(currentVehicle);

            await LoadData();
            showReturnVehicle = false;
            successMessage = "Vehicle returned successfully.";
            returnMileage = 0;
            returnCondition = string.Empty;
        }
        catch (Exception ex) { errorMessage = $"Failed to return vehicle: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private async Task GenerateAndRequestOtp()
    {
        errorMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(requestApprover) || !requestApprover.Contains("@"))
        {
            errorMessage = "Please enter a valid Admin Email address.";
            return;
        }

        isSubmitting = true;
        StateHasChanged();

        try
        {
            // ✅ FIX: Verify the entered email belongs to a user with the Admin role
            Driver? adminRecord = null;
            try
            {
                adminRecord = await Supabase.From<Driver>()
                    .Filter("email", Postgrest.Constants.Operator.Equals, requestApprover.Trim())
                    .Filter("role", Postgrest.Constants.Operator.Equals, "Admin")
                    .Single();
            }
            catch { }

            if (adminRecord == null)
            {
                errorMessage = "The email entered does not belong to an Admin. Please ask your administrator for their email address.";
                return;
            }

            var random = new Random();
            generatedOtp = random.Next(100000, 999999).ToString();

            var requestRecord = new VehicleRequest
            {
                DriverEmail = currentUserEmail,
                VehicleId = requestedVehicleId,
                Mileage = requestMileage,
                AdminEmail = requestApprover.Trim(),
                OtpCode = generatedOtp,
                Status = "Pending"
            };

            await Supabase.From<VehicleRequest>().Insert(requestRecord);
            isOtpSent = true;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to send OTP: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private async Task SubmitVehicleRequest()
    {
        errorMessage = string.Empty;

        if (enteredOtp.Trim() != generatedOtp || string.IsNullOrEmpty(enteredOtp))
        {
            errorMessage = "Invalid OTP. Please enter the code sent to the administrator.";
            return;
        }

        isSubmitting = true;
        try
        {
            var vehicleResponse = await Supabase.From<Vehicle>()
                .Filter("id", Postgrest.Constants.Operator.Equals, requestedVehicleId)
                .Single();

            if (vehicleResponse == null) { errorMessage = "Vehicle not found."; return; }

            string driverDisplayName = currentUserEmail;
            try
            {
                var driverRecord = await Supabase.From<Driver>()
                    .Filter("email", Postgrest.Constants.Operator.Equals, currentUserEmail)
                    .Single();
                if (driverRecord != null)
                    driverDisplayName = driverRecord.Name;
            }
            catch { }

            vehicleResponse.Status = "Active";
            vehicleResponse.Mileage = requestMileage;
            vehicleResponse.LastDriver = driverDisplayName;
            await Supabase.From<Vehicle>().Update(vehicleResponse);

            await LoadData();
            showRequestVehicle = false;
            successMessage = $"Vehicle assigned successfully. Verified by Admin: {requestApprover}.";
            requestedVehicleId = string.Empty;
            requestMileage = 0;
            requestApprover = string.Empty;
            isOtpSent = false;
            enteredOtp = string.Empty;
        }
        catch (Exception ex) { errorMessage = $"Failed to assign vehicle: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private void CloseUpdateMileage()
    {
        showUpdateMileage = false;
        mileageServiceWarning = false;
        updateMileageValue = 0;
        Navigation.NavigateTo("/driver", replace: true);
    }

    private async Task SubmitUpdateMileage()
    {
        if (updateMileageValue <= 0)
        {
            errorMessage = "Please enter a valid mileage.";
            return;
        }
        isSubmitting = true;
        try
        {
            currentVehicle.Mileage = updateMileageValue;
            await Supabase.From<Vehicle>().Update(currentVehicle);

            mileageServiceWarning = currentVehicle.Mileage >= currentVehicle.ServiceDueKm;

            if (!mileageServiceWarning)
            {
                showUpdateMileage = false;
                Navigation.NavigateTo("/driver", replace: true);
                successMessage = "Mileage updated successfully.";
            }
        }
        catch (Exception ex) { errorMessage = $"Failed to update mileage: {ex.Message}"; }
        finally { isSubmitting = false; }
    }
}