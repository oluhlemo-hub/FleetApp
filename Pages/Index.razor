@page "/"
@layout EmptyLayout
@using FleetManagement.Services
@inject FleetService FleetService
@inject NavigationManager Nav

<div class="container d-flex flex-column align-items-center justify-content-center" style="height: 100vh;">
    <div class="card p-4 shadow-sm" style="width: 100%; max-width: 400px; border-radius: 20px; border: none;">
        <div class="text-center mb-4">
            <img src="images/logo.png" alt="Fleet Portal Logo" style="width: 80px; height: 80px; object-fit: contain;" />
            <h2 class="fw-bold mt-2">Fleet Portal</h2>
            <p class="text-muted">Sign in to manage your vehicle</p>
        </div>
        <div class="mb-3">
            <label class="form-label fw-bold small">Email Address</label>
            <input type="email" @bind="UserEmail" class="form-control form-control-lg"
                   placeholder="name@company.com" />
        </div>
        <div class="mb-4">
            <label class="form-label fw-bold small">Password</label>
            <input type="password" @bind="Password" class="form-control form-control-lg"
                   placeholder="••••••••"
                   @onkeydown="HandleKeyDown" />
        </div>
        <button class="btn btn-primary btn-lg w-100 mb-3"
                @onclick="HandleLogin"
                style="border-radius: 10px;"
                disabled="@(isLoading)">
            @if (isLoading)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
                <span>Signing in...</span>
            }
            else
            {
                <span>Sign In</span>
            }
        </button>
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger py-2 small text-center">
                <i class="bi bi-exclamation-circle me-1"></i> @ErrorMessage
            </div>
        }
    </div>
</div>

@code {
    private string UserEmail { get; set; } = "";
    private string Password { get; set; } = "";
    private string ErrorMessage { get; set; } = "";
    private bool isLoading = false;

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleLogin();
    }

    private async Task HandleLogin()
    {
        ErrorMessage = "";
        if (string.IsNullOrWhiteSpace(UserEmail) || string.IsNullOrWhiteSpace(Password))
        {
            ErrorMessage = "Please enter your email and password.";
            return;
        }
        isLoading = true;
        StateHasChanged();
        try
        {
            var role = await FleetService.LoginAsync(UserEmail, Password);
            if (role == "Admin")
            {
                Nav.NavigateTo("/admin");
            }
            else if (role == "Driver")
            {
                Nav.NavigateTo("/driver");
            }
            else if (role == "Inactive")
            {
                ErrorMessage = "Your account has been deactivated. Contact your administrator.";
            }
            else
            {
                ErrorMessage = "Invalid email or password.";
            }
        }
        catch (Exception)
        {
            ErrorMessage = "Invalid email or password.";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}