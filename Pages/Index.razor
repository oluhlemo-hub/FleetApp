<div class="login-overlay"></div>

    <div class="login-content">
    <div class="fleet-login-card">
        <div class="fleet-login-logo">
            <img src="images/logo.png" alt="Fleet Portal" />
        </div>
        <div class="fleet-login-title">Fleet Portal</div>
        <div class="fleet-login-sub">Sign in to manage your fleet</div>
        <div class="fleet-divider"></div>

        @if (!showForgotPassword)
        {
            <div class="fleet-input-wrap">
                <i class="bi bi-envelope fleet-input-icon"></i>
                <input type="email" @bind="UserEmail" class="form-control fleet-input" placeholder="name@company.com" />
            </div>
            <div class="fleet-input-wrap">
                <i class="bi bi-lock fleet-input-icon"></i>
                <input type="password" @bind="Password" class="form-control fleet-input" placeholder="••••••••" @onkeydown="HandleKeyDown" />
            </div>
            <button class="fleet-login-btn" @onclick="HandleLogin" disabled="@isLoading">
                @if (isLoading) { <span class="spinner-border spinner-border-sm"></span><span>Signing in...</span> }
                else { <span>Sign in</span> }
            </button>
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="fleet-login-error"><i class="bi bi-exclamation-circle me-1"></i> @ErrorMessage</div>
            }
            <button class="fleet-forgot-link" @onclick="() => { showForgotPassword = true; ErrorMessage = string.Empty; }">Forgot password?</button>
        }
        else
        {
            <div class="fleet-forgot-section">
                <div class="fleet-forgot-title">Reset your password</div>
                <div class="fleet-forgot-sub">Enter your email and we will send you a reset link.</div>
                <div class="fleet-input-wrap">
                    <i class="bi bi-envelope fleet-input-icon"></i>
                    <input type="email" @bind="ResetEmail" class="form-control fleet-input" placeholder="name@company.com" />
                </div>
                <button class="fleet-login-btn" @onclick="HandleForgotPassword" disabled="@isResetting">
                    @if (isResetting) { <span class="spinner-border spinner-border-sm"></span><span>Sending...</span> }
                    else { <span>Send reset link</span> }
                </button>
                @if (!string.IsNullOrEmpty(ResetMessage))
                {
                    <div class="fleet-login-success"><i class="bi bi-check-circle me-1"></i> @ResetMessage</div>
                }
                <button class="fleet-forgot-link" @onclick="() => { showForgotPassword = false; ResetMessage = string.Empty; }">Back to sign in</button>
            </div>
        }
    </div>
    <div class="login-footer">Powered by <span style="color:rgba(55,138,221,0.8);font-weight:600;">Fearless Tech</span></div>
    </div>
</div>

@code {
    private string UserEmail { get; set; } = "";
    private string Password { get; set; } = "";
    private string ErrorMessage { get; set; } = "";
    private string ResetEmail { get; set; } = "";
    private string ResetMessage { get; set; } = "";
    private bool isLoading = false;
    private bool isResetting = false;
    private bool showForgotPassword = false;

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleLogin();
    }

    private async Task HandleForgotPassword()
    {
        ResetMessage = string.Empty;
        if (string.IsNullOrWhiteSpace(ResetEmail)) { ResetMessage = "Please enter your email address."; return; }
        isResetting = true;
        StateHasChanged();
        try
        {
            await FleetService.SendPasswordResetAsync(ResetEmail.Trim());
            ResetMessage = "Reset link sent! Check your inbox.";
            ResetEmail = string.Empty;
        }
        catch { ResetMessage = "Failed to send reset link. Please try again."; }
        finally { isResetting = false; StateHasChanged(); }
    }

    private async Task HandleLogin()
    {
        ErrorMessage = "";
        if (string.IsNullOrWhiteSpace(UserEmail) || string.IsNullOrWhiteSpace(Password))
        {
            ErrorMessage = "Please enter your email and password.";
            return;
        }
        isLoading = true;
        StateHasChanged();
        try
        {
            var role = await FleetService.LoginAsync(UserEmail, Password);
            if (role == "Admin")
            {
                try
                {
                    var adminRecord = await Supabase.From<Driver>()
                        .Filter("email", Postgrest.Constants.Operator.Equals, UserEmail)
                        .Single();
                    if (adminRecord?.HasCompletedSetup == false)
                        Nav.NavigateTo("/setup");
                    else
                        Nav.NavigateTo("/admin");
                }
                catch { Nav.NavigateTo("/admin"); }
            }
            else if (role == "Driver")
            {
                try
                {
                    var driverRecord = await Supabase.From<Driver>()
                        .Filter("email", Postgrest.Constants.Operator.Equals, UserEmail)
                        .Single();
                    if (driverRecord?.MustChangePassword == true)
                        Nav.NavigateTo("/change-password");
                    else if (driverRecord?.HasCompletedSetup == false)
                        Nav.NavigateTo("/setup");
                    else
                        Nav.NavigateTo("/driver");
                }
                catch { Nav.NavigateTo("/driver"); }
            }
            else if (role == "Inactive") { ErrorMessage = "Your account has been deactivated. Contact your administrator."; }
            else { ErrorMessage = "Invalid email or password."; }
        }
        catch { ErrorMessage = "Invalid email or password."; }
        finally { isLoading = false; StateHasChanged(); }
    }
}
