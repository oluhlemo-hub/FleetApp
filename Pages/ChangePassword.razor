@page "/change-password"
@layout EmptyLayout
@using FleetManagement.Models
@inject Supabase.Client Supabase
@inject NavigationManager Nav

<div class="container d-flex flex-column align-items-center justify-content-center" style="height: 100vh;">
    <div class="card p-4 shadow-sm" style="width: 100%; max-width: 400px; border-radius: 20px; border: none;">
        <div class="text-center mb-4">
            <i class="bi bi-shield-lock display-4 text-primary"></i>
            <h2 class="fw-bold mt-2">Set Your Password</h2>
            <p class="text-muted small">Choose a new password to secure your account.</p>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold small">New Password</label>
            <input type="password" @bind="newPassword" class="form-control form-control-lg"
                   placeholder="Min 8 characters" />
        </div>
        <div class="mb-4">
            <label class="form-label fw-bold small">Confirm Password</label>
            <input type="password" @bind="confirmPassword" class="form-control form-control-lg"
                   placeholder="Repeat your password" />
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger py-2 small text-center">
                <i class="bi bi-exclamation-circle me-1"></i> @errorMessage
            </div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success py-2 small text-center">@successMessage</div>
        }

        <button class="btn btn-primary btn-lg w-100" @onclick="HandleChangePassword"
                style="border-radius: 10px;" disabled="@isLoading">
            @if (isLoading)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
                <span>Saving...</span>
            }
            else
            {
                <span>Set Password</span>
            }
        </button>
    </div>
</div>

@code {
    private string newPassword = "";
    private string confirmPassword = "";
    private string errorMessage = "";
    private string successMessage = "";
    private bool isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        // Guard: if no active session, send back to login
        for (int i = 0; i < 10; i++)
        {
            if (Supabase.Auth.CurrentSession != null) break;
            await Task.Delay(200);
        }

        if (Supabase.Auth.CurrentSession == null)
        {
            Nav.NavigateTo("/");
            return;
        }
    }

    private async Task HandleChangePassword()
    {
        errorMessage = "";

        if (newPassword.Length < 8)
        {
            errorMessage = "Password must be at least 8 characters.";
            return;
        }
        if (newPassword != confirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        isLoading = true;
        StateHasChanged();

        try
        {
            // Update password in Supabase Auth
            await Supabase.Auth.Update(new Supabase.Gotrue.UserAttributes
            {
                Password = newPassword
            });

            // Clear the must_change_password flag on the driver record
            var userEmail = Supabase.Auth.CurrentSession?.User?.Email;
            if (userEmail != null)
            {
                var driver = await Supabase.From<Driver>()
                    .Filter("email", Postgrest.Constants.Operator.Equals, userEmail)
                    .Single();

                if (driver != null)
                {
                    driver.MustChangePassword = false;
                    await Supabase.From<Driver>().Update(driver);
                }
            }

            successMessage = "Password updated! Redirecting...";
            StateHasChanged();
            await Task.Delay(1500);
            Nav.NavigateTo("/driver");
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to update password: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}