@page "/change-password"
@layout EmptyLayout
@using FleetManagement.Models
@using static Supabase.Gotrue.Constants
@inject Supabase.Client Supabase
@inject NavigationManager Nav
@inject IJSRuntime JS

<style>
    .fleet-login-page { min-height: 100vh; background: #042C53; display: flex; align-items: center; justify-content: center; padding: 1rem; }
    .fleet-login-card { width: 100%; max-width: 400px; background: #031f3a; border: 0.5px solid #185FA5; border-radius: 20px; padding: 2.5rem 2rem; display: flex; flex-direction: column; align-items: center; }
    .fleet-login-title { color: #B5D4F4; font-size: 1.5rem; font-weight: 500; margin-bottom: 0.25rem; text-align: center; }
    .fleet-login-sub { color: #378ADD; font-size: 0.85rem; margin-bottom: 2rem; text-align: center; }
    .fleet-divider { width: 100%; height: 0.5px; background: #185FA5; margin-bottom: 1.5rem; }
    .fleet-input-wrap { width: 100%; position: relative; margin-bottom: 1rem; }
    .fleet-input-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #378ADD; font-size: 1rem; pointer-events: none; }
    .fleet-input { width: 100%; height: 48px; background: #042C53 !important; border: 0.5px solid #185FA5 !important; border-radius: 10px !important; padding-left: 42px !important; color: #B5D4F4 !important; font-size: 0.95rem; }
    .fleet-input::placeholder { color: #378ADD; opacity: 0.6; }
    .fleet-input:focus { outline: none !important; box-shadow: 0 0 0 2px #185FA5 !important; border-color: #378ADD !important; }
    .fleet-login-btn { width: 100%; height: 48px; background: #378ADD; border: none; border-radius: 10px; color: #042C53; font-size: 1rem; font-weight: 500; margin-top: 0.5rem; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; }
    .fleet-login-btn:hover:not(:disabled) { background: #B5D4F4; }
    .fleet-login-btn:disabled { opacity: 0.7; cursor: not-allowed; }
    .fleet-login-error { width: 100%; margin-top: 1rem; background: #501313; border: 0.5px solid #A32D2D; border-radius: 8px; padding: 0.6rem 1rem; color: #F7C1C1; font-size: 0.85rem; text-align: center; }
    .fleet-login-success { width: 100%; margin-top: 1rem; background: #04342C; border: 0.5px solid #1D9E75; border-radius: 8px; padding: 0.6rem 1rem; color: #9FE1CB; font-size: 0.85rem; text-align: center; }
</style>

<div class="fleet-login-page">
    <div class="fleet-login-card">
        <div style="width:64px;height:64px;background:#185FA5;border-radius:16px;display:flex;align-items:center;justify-content:center;margin-bottom:1.25rem;">
            <i class="bi bi-shield-lock" style="font-size:1.75rem;color:#B5D4F4;"></i>
        </div>
        <div class="fleet-login-title">Set New Password</div>
        <div class="fleet-login-sub">Choose a secure password for your account</div>
        <div class="fleet-divider"></div>

        @if (isLoadingSession)
        {
            <div style="color:#378ADD;font-size:0.9rem;text-align:center;">
                <span class="spinner-border spinner-border-sm me-2"></span> Verifying reset link...
            </div>
        }
        else if (sessionReady)
        {
            <div class="fleet-input-wrap">
                <i class="bi bi-lock fleet-input-icon"></i>
                <input type="password" @bind="newPassword" class="form-control fleet-input" placeholder="Min 8 characters" />
            </div>
            <div class="fleet-input-wrap">
                <i class="bi bi-lock-fill fleet-input-icon"></i>
                <input type="password" @bind="confirmPassword" class="form-control fleet-input" placeholder="Repeat your password" />
            </div>
            <button class="fleet-login-btn" @onclick="HandleChangePassword" disabled="@isLoading">
                @if (isLoading) { <span class="spinner-border spinner-border-sm"></span><span>Saving...</span> }
                else { <span>Set password</span> }
            </button>
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="fleet-login-error"><i class="bi bi-exclamation-circle me-1"></i> @errorMessage</div>
            }
            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="fleet-login-success"><i class="bi bi-check-circle me-1"></i> @successMessage</div>
            }
        }
        else
        {
            <div class="fleet-login-error">
                <i class="bi bi-exclamation-circle me-1"></i> @(string.IsNullOrEmpty(errorMessage) ? "Invalid or expired reset link. Please request a new one." : errorMessage)
            </div>
            <button class="fleet-login-btn" style="margin-top:1rem;" @onclick='() => Nav.NavigateTo("/")'>
                Back to sign in
            </button>
        }
    </div>
</div>

@code {
    private string newPassword = "";
    private string confirmPassword = "";
    private string errorMessage = "";
    private string successMessage = "";
    private bool isLoading = false;
    private bool isLoadingSession = true;
    private bool sessionReady = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            // Get the URL hash which contains the access_token from Supabase reset email
            var hash = await JS.InvokeAsync<string>("eval", "window.location.hash");

            if (!string.IsNullOrEmpty(hash) && hash.Contains("access_token"))
            {
                // Parse access_token and refresh_token from hash
                var parts = hash.TrimStart('#').Split('&');
                var tokenDict = parts
                    .Select(p => p.Split('='))
                    .Where(p => p.Length == 2)
                    .ToDictionary(p => p[0], p => Uri.UnescapeDataString(p[1]));

                if (tokenDict.TryGetValue("access_token", out var accessToken))
                {
                    var email = tokenDict.ContainsKey("email") ? tokenDict["email"] : "";
                    await Supabase.Auth.VerifyOTP(email, accessToken, EmailOtpType.Recovery);
                    sessionReady = true;
                }
            }
            else
            {
                // Already logged in (first-login password change)
                for (int i = 0; i < 10; i++)
                {
                    if (Supabase.Auth.CurrentSession != null) { sessionReady = true; break; }
                    await Task.Delay(200);
                }
            }
        }
        catch (Exception ex) { sessionReady = false; errorMessage = ex.Message; }

        isLoadingSession = false;
        StateHasChanged();
    }

    private async Task HandleChangePassword()
    {
        errorMessage = "";
        if (newPassword.Length < 8) { errorMessage = "Password must be at least 8 characters."; return; }
        if (newPassword != confirmPassword) { errorMessage = "Passwords do not match."; return; }
        isLoading = true;
        StateHasChanged();
        try
        {
            var attributes = new Supabase.Gotrue.UserAttributes { Password = newPassword };
            await Supabase.Auth.Update(attributes);

            var userEmail = Supabase.Auth.CurrentSession?.User?.Email;
            if (userEmail != null)
            {
                try
                {
                    var driver = await Supabase.From<Driver>()
                        .Filter("email", Postgrest.Constants.Operator.Equals, userEmail)
                        .Single();
                    if (driver != null)
                    {
                        driver.MustChangePassword = false;
                        await Supabase.From<Driver>().Update(driver);
                    }
                }
                catch { }
            }

            successMessage = "Password updated! Redirecting to login...";
            StateHasChanged();
            await Task.Delay(1500);
            await Supabase.Auth.SignOut();
            Nav.NavigateTo("/");
        }
        catch (Exception ex) { errorMessage = $"Failed to update password: {ex.Message}"; }
        finally { isLoading = false; StateHasChanged(); }
    }
}
